{
  "type": "object",
  "required": ["verdict", "summary"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["clean", "issues_found"]
    },
    "summary": {
      "type": "string"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "description"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["blocker", "concern", "nit"]
          },
          "description": { "type": "string" },
          "file": { "type": "string" },
          "line": { "type": "integer" }
        }
      }
    }
  }
}
