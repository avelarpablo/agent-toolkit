#!/bin/bash
# ralph-core — AFK agent runner for the discount-genie-core multi-repo workspace.
#
# Adapts the global ralph (one-repo-per-run) for a workspace where issues are
# tracked on the core repo but code lives in nested sub-repos with their own
# git histories.
#
# Usage:
#   ./ralph/ralph-core once [--issue N] [--prd N] [--allow-risky] [--schedule "YYYY-MM-DD HH:MM"]
#   ./ralph/ralph-core loop [--max N] [--prd N] [--allow-risky] [--schedule "YYYY-MM-DD HH:MM"]
#   ./ralph/ralph-core resume RUN_ID [--schedule "YYYY-MM-DD HH:MM"]
#   ./ralph/ralph-core resume list
#   ./ralph/ralph-core schedule list|show|logs|cancel JOB_ID
#   ./ralph/ralph-core check
#   ./ralph/ralph-core init

set -euo pipefail
[[ "${RALPH_VERBOSE:-0}" == "1" ]] && set -x

# ── Workspace constants ──────────────────────────────────────────────────────
CORE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
BACKEND_DIR="$CORE_ROOT/discount-genie-backend"
FRONTEND_DIR="$CORE_ROOT/discount-genie"
CORE_REPO="shopstackio/discount-genie-core"
RALPH_DIR="$CORE_ROOT/ralph"
SCHEMA="$RALPH_DIR/review-schema.json"
LOCK_FILE="$RALPH_DIR/.run.lock"
RUN_DIR="$RALPH_DIR/runs"
SCHED_DIR="$RALPH_DIR/schedules"
SCHED_LOG_DIR="$RALPH_DIR/logs/scheduled"
LIB="$RALPH_DIR/lib/core.py"

# ── Account resolution (from ~/.ralph/accounts.toml, same as global ralph) ───
ACCOUNTS_FILE="$HOME/.ralph/accounts.toml"

_flatten_toml() {
  python3 -c "
import sys, re
section = ''
for line in open(sys.argv[1]):
    line = line.strip()
    if not line or line.startswith('#'):
        continue
    m = re.match(r'\[(.+)\]', line)
    if m:
        section = m.group(1) + '.'
        continue
    if '=' in line:
        print(section + line)
" "$1"
}

_resolve_account() {
  ACCOUNT="default"
  export CLAUDE_CONFIG_DIR="$HOME/.claude"
  export CODEX_HOME="$HOME/.codex"
  GH_CONFIG_DIR_RESOLVED=""

  if [[ ! -f "$ACCOUNTS_FILE" ]]; then
    return
  fi

  local best_name="" best_len=0
  while IFS= read -r line; do
    local key="${line%%=*}"
    local val="${line#*=}"
    key=$(echo "$key" | xargs)
    val=$(echo "$val" | xargs | tr -d '"' | sed "s|^~|$HOME|")
    if [[ "$key" == accounts.*.path ]]; then
      local name="${key#accounts.}"
      name="${name%.path}"
      if [[ "$CORE_ROOT" == "$val"/* || "$CORE_ROOT" == "$val" ]]; then
        if (( ${#val} > best_len )); then
          best_name="$name"
          best_len=${#val}
        fi
      fi
    fi
  done < <(_flatten_toml "$ACCOUNTS_FILE")

  if [[ -z "$best_name" ]]; then
    return
  fi

  ACCOUNT="$best_name"
  while IFS= read -r line; do
    local key="${line%%=*}"
    local val="${line#*=}"
    key=$(echo "$key" | xargs)
    val=$(echo "$val" | xargs | tr -d '"' | sed "s|^~|$HOME|")
    case "$key" in
      "accounts.${best_name}.claude_config_dir") export CLAUDE_CONFIG_DIR="$val" ;;
      "accounts.${best_name}.codex_home")        export CODEX_HOME="$val" ;;
      "accounts.${best_name}.gh_config_dir")     GH_CONFIG_DIR_RESOLVED="$val" ;;
      "accounts.${best_name}.gh_host")           export GH_HOST="$val" ;;
    esac
  done < <(_flatten_toml "$ACCOUNTS_FILE")

  if [[ -n "$GH_CONFIG_DIR_RESOLVED" ]]; then
    export GH_CONFIG_DIR="$GH_CONFIG_DIR_RESOLVED"
  fi
}

_resolve_account

MODEL="${RALPH_MODEL:-claude-opus-4-6}"
EFFORT="${RALPH_EFFORT:-medium}"
CODEX_MODEL="${RALPH_CODEX_MODEL:-gpt-5.5}"

# ── Protected branches ───────────────────────────────────────────────────────
PROTECTED_BRANCHES="main develop staging"
FEATURE_BRANCH="${RALPH_FEATURE_BRANCH:-}"

# ── Colors + logging (all to stderr) ─────────────────────────────────────────
_R="\033[0m"; _BOLD="\033[1m"; _DIM="\033[2m"
_RALPH="\033[34m"; _WARN="\033[33m"; _ERR="\033[31m"; _OK="\033[32m"

log()  { printf "${_RALPH}${_BOLD}[ralph-core]${_R} ${_DIM}$(date '+%H:%M:%S')${_R} %s\n" "$*" >&2; }
warn() { printf "${_WARN}${_BOLD}[ralph-core]${_R} ${_DIM}$(date '+%H:%M:%S')${_R} ${_WARN}WARN${_R}  %s\n" "$*" >&2; }
die()  { printf "${_ERR}${_BOLD}[ralph-core]${_R} ${_DIM}$(date '+%H:%M:%S')${_R} ${_ERR}ERROR${_R} %s\n" "$*" >&2; exit 1; }

# ── State + footer libraries (from global ralph) ─────────────────────────────
if [[ -f "$HOME/.ralph/lib/state.sh" ]]; then
  source "$HOME/.ralph/lib/state.sh"
  source "$HOME/.ralph/lib/footer.sh"
fi

# ── Workspace lock ───────────────────────────────────────────────────────────

_lock_read_state() {
  local _state
  _state=$(python3 "$LIB" json-get "$LOCK_FILE" pid host command started 2>/dev/null) \
    || _state=$'\t\t\t'
  IFS=$'\t' read -r _LOCK_PID _LOCK_HOST _LOCK_CMD _LOCK_STARTED <<< "$_state"
}

_lock_acquire() {
  local cmd_str="${1:-}"
  local hostname
  hostname=$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo "unknown")

  local _lock_payload
  _lock_payload=$(python3 "$LIB" lock-payload "$$" "$hostname" "$cmd_str" "$CORE_ROOT")

  if ( set -o noclobber; printf '%s\n' "$_lock_payload" > "$LOCK_FILE" ) 2>/dev/null; then
    log "Lock acquired (PID $$)"
    return 0
  fi

  if [[ -f "$LOCK_FILE" ]]; then
    _lock_read_state
    local lock_pid="$_LOCK_PID" lock_host="$_LOCK_HOST"

    if [[ -z "$lock_pid" ]]; then
      die "workspace is locked (lock metadata unreadable — retry; remove $LOCK_FILE only if no ralph-core is running)"
    fi

    if [[ -n "$lock_host" && "$lock_host" != "$hostname" ]]; then
      warn "Lock held by different host ($lock_host)"
      cat "$LOCK_FILE" >&2
      die "lock held by different host '$lock_host'"
    fi

    if [[ -n "$lock_pid" ]] && kill -0 "$lock_pid" 2>/dev/null; then
      die "workspace is locked by active PID $lock_pid (command: ${_LOCK_CMD:-?}) — stop it or remove $LOCK_FILE"
    fi

    local _stale_pid_seen="$lock_pid"
    local _stale_guard="${LOCK_FILE}.stale_lock"
    if ! mkdir "$_stale_guard" 2>/dev/null; then
      die "workspace is locked (concurrent stale cleanup in progress — retry)"
    fi

    _lock_read_state
    if [[ "$_LOCK_PID" != "$_stale_pid_seen" ]]; then
      rmdir "$_stale_guard" 2>/dev/null || true
      die "lock was replaced by another process while waiting"
    fi

    log "Removing stale lock (PID ${lock_pid:-?} is dead)"
    rm -f "$LOCK_FILE"
    local _acquired=0
    ( set -o noclobber; printf '%s\n' "$_lock_payload" > "$LOCK_FILE" ) 2>/dev/null && _acquired=1
    rmdir "$_stale_guard" 2>/dev/null || true

    if [[ $_acquired -eq 1 ]]; then
      log "Lock acquired (PID $$)"
      return 0
    fi
  fi

  die "workspace is locked by another process"
}

_lock_release() {
  if [[ -f "$LOCK_FILE" ]]; then
    local lock_pid
    lock_pid=$(python3 "$LIB" json-get "$LOCK_FILE" pid 2>/dev/null || echo "")
    if [[ "$lock_pid" == "$$" ]]; then
      rm -f "$LOCK_FILE"
    fi
  fi
}

# ── Schedule OS backends ─────────────────────────────────────────────────────

_sched_register() {
  local job_id="$1" run_at_epoch="$2" run_at_iso="$3" log_path="$4"
  _SCHED_BACKEND="none"
  _SCHED_BACKEND_ID="none"

  local os ralph_bin="$CORE_ROOT/ralph/ralph-core"
  os=$(uname -s)

  local _sched_env_keys=(RALPH_FEATURE_BRANCH RALPH_MODEL CLAUDE_CONFIG_DIR CODEX_HOME GH_CONFIG_DIR RALPH_DIFF_LINES)
  local _ralph_var
  for _ralph_var in $(compgen -v RALPH_ 2>/dev/null || true); do
    local _already=0 _existing
    for _existing in "${_sched_env_keys[@]}"; do
      [[ "$_existing" == "$_ralph_var" ]] && { _already=1; break; }
    done
    [[ "$_already" -eq 0 ]] && _sched_env_keys+=("$_ralph_var")
  done

  if [[ "$os" == "Darwin" ]]; then
    local plist_id="com.ralph-core.${job_id}"
    local plist_path="$HOME/Library/LaunchAgents/${plist_id}.plist"
    local cal_parts
    cal_parts=$(python3 "$LIB" plist-cal "$run_at_epoch")
    read -r _pm _pd _ph _pmin <<< "$cal_parts"
    mkdir -p "$HOME/Library/LaunchAgents"
    local _plist_env_extra="" _k _v
    for _k in "${_sched_env_keys[@]}"; do
      _v="${!_k:-}"
      if [[ -n "$_v" ]]; then
        _v="${_v//&/&amp;}"; _v="${_v//</&lt;}"; _v="${_v//>/&gt;}"
        _plist_env_extra+="        <key>${_k}</key>"$'\n'"        <string>${_v}</string>"$'\n'
      fi
    done
    cat > "$plist_path" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${plist_id}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${ralph_bin}</string>
        <string>run-scheduled</string>
        <string>${job_id}</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Month</key><integer>${_pm}</integer>
        <key>Day</key><integer>${_pd}</integer>
        <key>Hour</key><integer>${_ph}</integer>
        <key>Minute</key><integer>${_pmin}</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>${log_path}</string>
    <key>StandardErrorPath</key>
    <string>${log_path}</string>
    <key>WorkingDirectory</key>
    <string>${CORE_ROOT}</string>
    <key>RunAtLoad</key>
    <false/>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>${PATH}</string>
        <key>HOME</key>
        <string>${HOME}</string>
${_plist_env_extra}    </dict>
</dict>
</plist>
PLIST
    if ! launchctl load "$plist_path" 2>/dev/null; then
      warn "launchctl load failed — OS job not registered"
      rm -f "$plist_path"
      return 1
    fi
    _SCHED_BACKEND="launchd"
    _SCHED_BACKEND_ID="$plist_id"

  else
    local _sched_setenv_args=() _sched_env_prefix="" _k _v
    for _k in "${_sched_env_keys[@]}"; do
      _v="${!_k:-}"
      if [[ -n "$_v" ]]; then
        _sched_setenv_args+=( "--setenv=${_k}=${_v}" )
        _sched_env_prefix+=$(printf "%s='%s' " "$_k" "${_v//\'/\'\\\'\'}")
      fi
    done

    if systemctl --user status &>/dev/null 2>&1 && command -v systemd-run &>/dev/null; then
      local unit_name="ralph-core-${job_id}" cal_str
      cal_str=$(date -d "@$run_at_epoch" '+%Y-%m-%d %H:%M:00' 2>/dev/null \
        || python3 -c "from datetime import datetime; print(datetime.fromtimestamp(int('$run_at_epoch')).strftime('%Y-%m-%d %H:%M:00'))")
      systemd-run --user \
        --on-calendar="$cal_str" --unit="$unit_name" \
        --working-directory="$CORE_ROOT" --setenv="HOME=$HOME" \
        ${_sched_setenv_args[@]+"${_sched_setenv_args[@]}"} \
        /bin/sh -c '"$1" run-scheduled "$2" >> "$3" 2>&1' _ "$ralph_bin" "$job_id" "$log_path" \
        >> "$log_path" 2>&1 || { warn "systemd-run failed"; return 1; }
      _SCHED_BACKEND="systemd"
      _SCHED_BACKEND_ID="$unit_name"

    elif command -v at &>/dev/null; then
      local at_time
      at_time=$(date -d "@$run_at_epoch" '+%H:%M %Y-%m-%d' 2>/dev/null \
        || python3 -c "from datetime import datetime; print(datetime.fromtimestamp(int('$run_at_epoch')).strftime('%H:%M %Y-%m-%d'))")
      local at_out
      at_out=$(printf "cd '%s' && %s'%s' run-scheduled '%s' >> '%s' 2>&1\n" \
        "$CORE_ROOT" "$_sched_env_prefix" "$ralph_bin" "$job_id" "$log_path" | at "$at_time" 2>&1) \
        || { warn "at scheduling failed: $at_out"; return 1; }
      local at_job_id
      at_job_id=$(echo "$at_out" | grep -oE 'job [0-9]+' | grep -oE '[0-9]+' | head -1 || echo "?")
      _SCHED_BACKEND="at"
      _SCHED_BACKEND_ID="$at_job_id"

    else
      warn "No supported scheduler found (need launchd/systemd-run/at)"
      return 1
    fi
  fi
}

_sched_cancel() {
  local job_id="$1" backend="$2" backend_id="$3"
  case "$backend" in
    launchd)
      local plist_path="$HOME/Library/LaunchAgents/${backend_id}.plist"
      launchctl unload "$plist_path" 2>/dev/null || true
      rm -f "$plist_path"
      ;;
    systemd)
      systemctl --user stop "${backend_id}.timer" 2>/dev/null || true
      systemctl --user disable "${backend_id}.timer" 2>/dev/null || true
      ;;
    at)
      [[ "$backend_id" != "?" && "$backend_id" =~ ^[0-9]+$ ]] && atrm "$backend_id" 2>/dev/null || true
      ;;
    *) warn "_sched_cancel: unknown backend '$backend'" ;;
  esac
}

_schedule_create() {
  local _sc_cmd="$1" _sc_flags="$2" _sc_allow_risky="$3"
  local _sc_run_at_iso="$4" _sc_run_at_epoch="$5"
  local _sc_pf_decision="${6:-GO}" _sc_pf_warnings="${7:-}"
  local _sc_created_at
  _sc_created_at=$(date '+%Y-%m-%dT%H:%M:%S')

  _job_id="sched-$(python3 "$LIB" gen-id)"
  mkdir -p "$SCHED_DIR" "$SCHED_LOG_DIR"
  _sched_log_path="$SCHED_LOG_DIR/${_job_id}.log"

  python3 "$LIB" sched-create "$SCHED_DIR" \
    --job-id "$_job_id" --command "$_sc_cmd" --flags-json "$_sc_flags" \
    --run-at "$_sc_run_at_iso" --created-at "$_sc_created_at" \
    --allow-risky "$_sc_allow_risky" --log-path "$_sched_log_path" \
    --preflight-decision "$_sc_pf_decision" --preflight-warnings "$_sc_pf_warnings"

  _SCHED_BACKEND="none"; _SCHED_BACKEND_ID="none"
  if _sched_register "$_job_id" "$_sc_run_at_epoch" "$_sc_run_at_iso" "$_sched_log_path"; then
    python3 "$LIB" sched-update "$SCHED_DIR" "$_job_id" \
      "backend=${_SCHED_BACKEND}" "backend_id=${_SCHED_BACKEND_ID}"
  else
    python3 "$LIB" sched-update "$SCHED_DIR" "$_job_id" "status=failed"
    warn "schedule: OS job registration failed — marked as failed"
    return 1
  fi
}

# ── Preflight ────────────────────────────────────────────────────────────────

_claude_reset_epoch() {
  python3 "$LIB" reset-epoch "$1"
}

_is_usage_limit_message() {
  python3 "$LIB" is-exhaustion "$1" 2>/dev/null
}

_claude_auth_cache_file() {
  python3 "$LIB" auth-cache-path "$CLAUDE_CONFIG_DIR" 2>/dev/null || echo "/tmp/.ralph_claude_auth_default"
}

_claude_auth_cache_valid() {
  local cache_file
  cache_file="$(_claude_auth_cache_file)"
  [[ -f "$cache_file" ]] || return 1
  local mtime now
  mtime=$(stat -f%m "$cache_file" 2>/dev/null || stat -c%Y "$cache_file" 2>/dev/null || echo 0)
  now=$(date +%s)
  [[ $(( now - mtime )) -lt "${RALPH_CLAUDE_AUTH_CACHE_TTL:-300}" ]]
}

_preflight_issue_body_checks() {
  local issue_num="$1" route="$2"
  local pf_raw
  pf_raw=$(gh issue view "$issue_num" --repo "$CORE_REPO" \
    --json body,comments 2>/dev/null || echo '{"body":"","comments":[]}')
  echo "$pf_raw" | python3 "$LIB" preflight-check "$route" 2>/dev/null || true
}

_preflight() {
  local issue_num="${1:-}" route="${2:-}" allow_risky="${3:-0}" prd_cand_count="${4:-0}"
  local warnings=()
  JOURNAL_PREFLIGHT_DECISION="NO_GO"
  JOURNAL_PREFLIGHT_WARNINGS=""

  if ! command -v claude &>/dev/null; then
    log "preflight NO_GO: 'claude' not found on PATH"
    return 1
  fi

  local claude_check _auth_cache_file
  _auth_cache_file="$(_claude_auth_cache_file)"
  if [[ "${RALPH_PREFLIGHT_ALLOW_FUTURE_USAGE:-0}" != "1" ]] && _claude_auth_cache_valid; then
    log "preflight: claude auth verified (cached)"
    claude_check="OK"
  else
    claude_check=$(CLAUDE_CONFIG_DIR="$CLAUDE_CONFIG_DIR" claude --print 'reply: OK' 2>&1 | head -1) || true
    if [[ "$claude_check" == "OK" ]]; then
      touch "$_auth_cache_file"
    else
      rm -f "$_auth_cache_file"
    fi
  fi
  if [[ "$claude_check" != "OK" ]]; then
    if [[ "${RALPH_PREFLIGHT_ALLOW_FUTURE_USAGE:-0}" == "1" ]] && _is_usage_limit_message "$claude_check"; then
      local reset_epoch="${RALPH_PREFLIGHT_USAGE_RESET_EPOCH:-}"
      if [[ -z "$reset_epoch" ]]; then
        reset_epoch=$(_claude_reset_epoch "$claude_check" 2>/dev/null || true)
      fi
      if [[ -n "$reset_epoch" && -n "${RALPH_PREFLIGHT_SCHEDULE_EPOCH:-}" && "$RALPH_PREFLIGHT_SCHEDULE_EPOCH" -gt "$reset_epoch" ]]; then
        local reset_human
        reset_human=$(date -r "$reset_epoch" '+%Y-%m-%d %H:%M:%S %Z' 2>/dev/null || echo "$reset_epoch")
        log "preflight: usage limit detected; scheduled run is after reset ($reset_human) — GO"
      elif [[ -z "$reset_epoch" ]]; then
        warnings+=("Claude currently unavailable due to usage/session limit; reset time could not be determined")
      else
        log "preflight NO_GO: claude auth failed — ${claude_check:-no response}"
        return 1
      fi
    else
      log "preflight NO_GO: claude auth failed — ${claude_check:-no response}"
      return 1
    fi
  fi

  if ! gh api user --jq '.login' &>/dev/null; then
    log "preflight NO_GO: gh not authenticated"
    return 1
  fi

  if ! command -v codex &>/dev/null; then
    log "preflight NO_GO: 'codex' not found on PATH"
    return 1
  fi

  if [[ ! -f "$SCHEMA" ]]; then
    log "preflight NO_GO: review-schema.json missing: $SCHEMA"
    return 1
  fi

  if [[ ! -f "$HOME/.ralph/prompt.md" && ! -f "$RALPH_DIR/prompt.md" ]]; then
    log "preflight NO_GO: no prompt.md found"
    return 1
  fi

  if [[ -f "$LOCK_FILE" ]]; then
    local hostname
    hostname=$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo "unknown")
    _lock_read_state

    if [[ -z "$_LOCK_PID" ]]; then
      log "preflight NO_GO: lock metadata unreadable"
      return 1
    fi
    if [[ -n "$_LOCK_HOST" && "$_LOCK_HOST" != "$hostname" ]]; then
      log "preflight NO_GO: lock held by different host '$_LOCK_HOST'"
      return 1
    fi
    if [[ -n "$_LOCK_PID" ]] && kill -0 "$_LOCK_PID" 2>/dev/null; then
      log "preflight NO_GO: workspace locked by active PID $_LOCK_PID (command: ${_LOCK_CMD:-?})"
      return 1
    fi
    log "preflight: stale lock detected (PID ${_LOCK_PID:-?} dead) — will clean up on acquire"
  fi

  if [[ -n "$route" ]]; then
    local repo_dir
    repo_dir=$(_repo_dir "$route")
    if [[ ! -d "$repo_dir/.git" ]]; then
      log "preflight NO_GO: target sub-repo not a valid git repo: $repo_dir"
      return 1
    fi
  fi

  if [[ -n "$issue_num" ]]; then
    while IFS= read -r _pf_w; do
      [[ -n "$_pf_w" ]] && warnings+=("$_pf_w")
    done < <(_preflight_issue_body_checks "$issue_num" "$route")
  fi

  [[ "$prd_cand_count" -gt 4 ]] && warnings+=("PRD child queue has $prd_cand_count candidates (> 4)")

  if [[ ${#warnings[@]} -eq 0 ]]; then
    JOURNAL_PREFLIGHT_DECISION="GO"
    JOURNAL_PREFLIGHT_WARNINGS=""
    log "preflight: GO"
    return 0
  fi

  for w in "${warnings[@]}"; do warn "preflight WARN: $w"; done

  local _w="" _wi
  for _wi in "${warnings[@]}"; do
    [[ -n "$_w" ]] && _w="${_w}|${_wi}" || _w="$_wi"
  done
  JOURNAL_PREFLIGHT_WARNINGS="$_w"

  if [[ "$allow_risky" == "1" || "$allow_risky" == "true" ]]; then
    JOURNAL_PREFLIGHT_DECISION="GO_WITH_WARNINGS"
    log "preflight: GO_WITH_WARNINGS (--allow-risky set)"
    return 0
  else
    JOURNAL_PREFLIGHT_DECISION="NO_GO"
    log "preflight: NO_GO — pass --allow-risky to proceed"
    return 1
  fi
}

_preflight_issue_soft() {
  local issue_num="${1:-}" route="${2:-}" allow_risky="${3:-0}"
  local warnings=()
  JOURNAL_PREFLIGHT_DECISION="NO_GO"
  JOURNAL_PREFLIGHT_WARNINGS=""

  if [[ -n "$issue_num" ]]; then
    while IFS= read -r _pf_w; do
      [[ -n "$_pf_w" ]] && warnings+=("$_pf_w")
    done < <(_preflight_issue_body_checks "$issue_num" "$route")
  fi

  if [[ ${#warnings[@]} -eq 0 ]]; then
    JOURNAL_PREFLIGHT_DECISION="GO"
    JOURNAL_PREFLIGHT_WARNINGS=""
    log "preflight (issue): GO"
    return 0
  fi

  for w in "${warnings[@]}"; do warn "preflight WARN: $w"; done

  local _w="" _wi
  for _wi in "${warnings[@]}"; do
    [[ -n "$_w" ]] && _w="${_w}|${_wi}" || _w="$_wi"
  done
  JOURNAL_PREFLIGHT_WARNINGS="$_w"

  if [[ "$allow_risky" == "1" || "$allow_risky" == "true" ]]; then
    JOURNAL_PREFLIGHT_DECISION="GO_WITH_WARNINGS"
    log "preflight (issue): GO_WITH_WARNINGS (--allow-risky set)"
    return 0
  else
    JOURNAL_PREFLIGHT_DECISION="NO_GO"
    log "preflight (issue): NO_GO — pass --allow-risky to proceed"
    return 1
  fi
}

# ── Issue routing ────────────────────────────────────────────────────────────

_route_issue() {
  local title="$1"
  case "$title" in
    BE:*|be:*) echo "backend" ;;
    FE:*|fe:*) echo "frontend" ;;
    PRD:*|prd:*) echo "prd" ;;
    *) echo "unknown" ;;
  esac
}

_repo_dir() {
  case "$1" in
    backend)  echo "$BACKEND_DIR" ;;
    frontend) echo "$FRONTEND_DIR" ;;
    *) echo "" ;;
  esac
}

_repo_name() {
  case "$1" in
    backend)  echo "discount-genie-backend" ;;
    frontend) echo "discount-genie" ;;
    *) echo "" ;;
  esac
}

# ── Downstream unlock ────────────────────────────────────────────────────────

_unlock_downstream() {
  local closed_issues="$1"

  local all_issues
  all_issues=$(gh issue list --repo "$CORE_REPO" --state open \
    --json number,body,labels --limit 500 2>/dev/null || echo "[]")

  local candidates
  candidates=$(echo "$all_issues" | python3 -c "
import sys, json, re
issues = json.load(sys.stdin)
human_labels = {'ready-for-human', 'needs-triage', 'needs-info', 'wontfix'}
for issue in issues:
    num = issue['number']
    labels = {l['name'] for l in issue.get('labels', [])}
    if 'ready-for-agent' in labels:
        continue
    if human_labels & labels:
        continue
    body = issue.get('body') or ''
    m = re.search(r'## Blocked by\n(.*?)(?:\n## |\Z)', body, re.DOTALL)
    if not m:
        continue
    blockers = re.findall(r'#(\d+)', m.group(1))
    if blockers:
        print(f'{num}\t{\",\".join(blockers)}')
" 2>/dev/null || true)

  [[ -z "$candidates" ]] && return 0

  while IFS=$'\t' read -r num blocker_list; do
    local all_closed=true
    IFS=',' read -ra blocker_arr <<< "$blocker_list"
    for b in "${blocker_arr[@]}"; do
      local state
      state=$(gh issue view "$b" --repo "$CORE_REPO" --json state --jq '.state' 2>/dev/null || echo "OPEN")
      if [[ "$state" != "CLOSED" ]]; then
        all_closed=false
        break
      fi
    done
    if $all_closed; then
      log "Unlocking downstream issue #$num (all blockers closed)"
      gh issue edit "$num" --repo "$CORE_REPO" --add-label ready-for-agent 2>/dev/null || true
    fi
  done <<< "$candidates"
}

# ── Blocker/parent extraction ────────────────────────────────────────────────

_extract_blockers() {
  echo "$1" | python3 "$LIB" md-refs "Blocked by" 2>/dev/null || true
}

_extract_parent() {
  echo "$1" | python3 "$LIB" md-refs "Parent" 2>/dev/null || true
}

# ── Shared eligibility engine ────────────────────────────────────────────────

_evaluate_issue() {
  local num="$1" title="$2" body="$3" labels_csv="$4" state="${5:-}"

  if [[ -n "$state" && "$state" != "OPEN" ]]; then
    echo "closed_issue||issue is not open (state=${state})"
    return 0
  fi

  if [[ "$title" == PRD:* || "$title" == prd:* ]]; then
    echo "prd_issue||detected as PRD/container issue"
    return 0
  fi

  local hard_blockers="needs-triage needs-info ready-for-human wontfix"
  for lbl in $hard_blockers; do
    if echo ",$labels_csv," | grep -qF ",$lbl,"; then
      echo "blocked_label:${lbl}||has hard-blocker label '${lbl}'"
      return 0
    fi
  done

  if ! echo ",$labels_csv," | grep -qF ",ready-for-agent,"; then
    echo "no_ready_label||missing ready-for-agent label"
    return 0
  fi

  local route
  route=$(_route_issue "$title")
  [[ "$route" == "prd" ]] && { echo "prd_issue||title has PRD: prefix"; return 0; }
  [[ "$route" == "unknown" ]] && { echo "unknown_route||title has no BE:/FE: prefix"; return 0; }

  local repo_dir
  repo_dir=$(_repo_dir "$route")
  if [[ ! -d "$repo_dir/.git" ]]; then
    echo "no_git_dir|${route}|sub-repo directory missing: $repo_dir"
    return 0
  fi

  if [[ -z "$body" ]]; then
    body=$(gh issue view "$num" --repo "$CORE_REPO" --json body --jq '.body' 2>/dev/null || echo "")
  fi

  local blockers
  blockers=$(_extract_blockers "$body")
  if [[ -n "$blockers" ]]; then
    for blocker_num in $blockers; do
      local blocker_state
      blocker_state=$(gh issue view "$blocker_num" --repo "$CORE_REPO" --json state --jq '.state' 2>/dev/null || echo "OPEN")
      if [[ "$blocker_state" != "CLOSED" ]]; then
        echo "blocker_open:${blocker_num}|${route}|blocker issue #${blocker_num} is still open"
        return 0
      fi
    done
  fi

  echo "eligible|${route}|"
  return 0
}

_pick_issue() {
  local issues_json
  issues_json=$(gh issue list --repo "$CORE_REPO" --state open \
    --label ready-for-agent --json number,title,labels --limit 100 \
    --jq 'sort_by(.number) | .[] | "\(.number)\(.title)\(.labels | map(.name) | join(","))"')

  [[ -z "$issues_json" ]] && return 1

  while IFS=$'\x1f' read -r num title labels_csv; do
    local result status route reason
    result=$(_evaluate_issue "$num" "$title" "" "$labels_csv")
    IFS='|' read -r status route reason <<< "$result"

    if [[ "$status" == "eligible" ]]; then
      echo "${num}|${title}|${route}"
      return 0
    else
      case "$status" in
        no_ready_label)    warn "Issue #$num missing ready-for-agent label — skipping: $title" ;;
        blocked_label:*)   warn "Issue #$num has hard-blocker label — skipping: $title" ;;
        blocker_open:*)    log  "Issue #$num is blocked (${status#blocker_open:}) — skipping" ;;
        prd_issue)         warn "Issue #$num is a PRD/container — skipping: $title" ;;
        unknown_route)     warn "Issue #$num has no BE:/FE: prefix — skipping: $title" ;;
        no_git_dir)        warn "Issue #$num targets $route but git dir missing — skipping" ;;
      esac
    fi
  done <<< "$issues_json"

  return 1
}

_pick_issue_from_prd() {
  local prd_num="$1" skip_nums="${2:-}"
  local issues
  issues=$(gh issue list --repo "$CORE_REPO" --state open \
    --label ready-for-agent --json number,title,labels,body --limit 100 2>/dev/null || true)

  [[ -z "$issues" || "$issues" == "[]" ]] && { log "No open ready-for-agent issues found for PRD #$prd_num"; return 1; }

  local parsed
  parsed=$(echo "$issues" | python3 "$LIB" prd-filter "$prd_num" 2>/dev/null || true)

  [[ -z "$parsed" ]] && { log "No open issues found with parent #$prd_num"; return 1; }

  local found_child=false rejection_lines=""
  while IFS=$'\x1f' read -r -d $'\x1e' num title labels_csv body; do
    body="${body//$'\x1d'/$'\n'}"
    [[ " $skip_nums " == *" $num "* ]] && continue
    found_child=true

    local result status route reason
    result=$(_evaluate_issue "$num" "$title" "$body" "$labels_csv")
    IFS='|' read -r status route reason <<< "$result"

    if [[ "$status" == "eligible" ]]; then
      echo "${num}|${title}|${route}"
      return 0
    else
      rejection_lines="${rejection_lines}  #${num} (${title:0:50}): ${status}${reason:+ — $reason}"$'\n'
    fi
  done <<< "$parsed"

  if ! $found_child; then
    log "No open issues found with parent #$prd_num"
  else
    log "Children of PRD #$prd_num — none eligible:"
    while IFS= read -r rl; do [[ -n "$rl" ]] && log "$rl"; done <<< "$rejection_lines"
  fi
  return 1
}

# ── Branch management ────────────────────────────────────────────────────────

_is_protected() {
  local branch="$1"
  for p in $PROTECTED_BRANCHES; do
    [[ "$branch" == "$p" ]] && return 0
  done
  return 1
}

_ensure_feature_branch() {
  local repo_dir="$1"
  local current
  [[ -n "$FEATURE_BRANCH" ]] && _is_protected "$FEATURE_BRANCH" && die "RALPH_FEATURE_BRANCH cannot be a protected branch ('$FEATURE_BRANCH')"
  current=$(git -C "$repo_dir" branch --show-current)

  if _is_protected "$current"; then
    if [[ -z "$FEATURE_BRANCH" ]]; then
      die "Sub-repo $(basename "$repo_dir") is on protected branch '$current' and RALPH_FEATURE_BRANCH is not set."
    fi
    log "Sub-repo $(basename "$repo_dir") is on protected branch '$current'" >&2
    if git -C "$repo_dir" show-ref --verify --quiet "refs/heads/$FEATURE_BRANCH" 2>/dev/null; then
      log "Feature branch '$FEATURE_BRANCH' exists — switching" >&2
      git -C "$repo_dir" checkout "$FEATURE_BRANCH" >&2
    else
      log "Creating '$FEATURE_BRANCH' from 'develop'" >&2
      git -C "$repo_dir" checkout develop 2>/dev/null >&2 || die "Cannot checkout develop in $(basename "$repo_dir")"
      git -C "$repo_dir" pull --ff-only origin develop 2>/dev/null >&2 || true
      git -C "$repo_dir" checkout -b "$FEATURE_BRANCH" >&2
    fi
    current="$FEATURE_BRANCH"
  fi
  echo "$current"
}

# ── Codex review gate ────────────────────────────────────────────────────────

_codex_gate_inconclusive() {
  local range_label="$1" repo_name="$2" closed_issues="$3" reason="$4"
  _CODEX_REVIEW_VERDICT="inconclusive"
  if [[ "${RALPH_GATE_STRICT:-0}" == "1" ]]; then
    warn "${reason} RALPH_GATE_STRICT=1 — failing closed."
    [[ -n "${RALPH_ITER:-}" && "$RALPH_ITER" != "resume" ]] && _state_update_iter "$RALPH_ITER" "blocked" \
      "verdict=inconclusive" 2>/dev/null || true
    local header="## Codex Review — INCONCLUSIVE (strict gate)

Reviewer: codex (${ACCOUNT}) | Range: \`${range_label}\` | Repo: ${repo_name}

${reason} \`RALPH_GATE_STRICT=1\` is set — failing closed."
    for n in $closed_issues; do
      gh issue reopen "$n" --repo "$CORE_REPO" || true
      gh issue edit "$n" --repo "$CORE_REPO" --add-label ready-for-agent || true
      gh issue comment "$n" --repo "$CORE_REPO" --body "$header" || true
    done
    log "Reopened: $closed_issues — will retry next iteration."
    return 1
  fi
  warn "${reason} Proceeding (set RALPH_GATE_STRICT=1 to fail closed)."
  [[ -n "${RALPH_ITER:-}" && "$RALPH_ITER" != "resume" ]] && _state_update_iter "$RALPH_ITER" "done" "verdict=inconclusive" 2>/dev/null || true
  return 0
}

_run_codex_review() {
  local repo_dir="$1" sha="$2" closed_issues="$3" before_sha="${4:-}"
  _CODEX_REVIEW_VERDICT=""

  if [[ "${RALPH_SKIP_CODEX:-0}" == "1" ]]; then
    log "RALPH_SKIP_CODEX=1 — skipping Codex review gate"
    _CODEX_REVIEW_VERDICT="skipped"
    return 0
  fi

  local commit_title repo_name
  commit_title=$(git -C "$repo_dir" log -1 --format="%s" "$sha" 2>/dev/null || echo "unknown")
  repo_name=$(basename "$repo_dir")

  mkdir -p "$RALPH_DIR/reviews"
  local ts result_file
  ts=$(date +%Y%m%dT%H%M%S)
  result_file="$RALPH_DIR/reviews/review-${ts}-${sha:0:8}.json"
  _CODEX_REVIEW_FILE="$result_file"

  local diff_stat diff_body range_label
  local diff_lines="${RALPH_DIFF_LINES:-800}"

  if [[ -n "$before_sha" && "$before_sha" != "$sha" ]]; then
    if ! git -C "$repo_dir" rev-parse --verify "${before_sha}^{commit}" &>/dev/null; then
      log "review FAIL: base revision $before_sha not found — reopening"
      for n in $closed_issues; do
        gh issue reopen "$n" --repo "$CORE_REPO" || true
        gh issue edit "$n" --repo "$CORE_REPO" --add-label ready-for-agent || true
      done
      return 1
    fi
    local commit_count
    commit_count=$(git -C "$repo_dir" rev-list --count "${before_sha}..${sha}" 2>/dev/null || echo "?")
    range_label="${before_sha:0:12}..${sha:0:12} (${commit_count} commit(s))"
    diff_stat=$({ git -C "$repo_dir" diff --stat "${before_sha}..${sha}" 2>/dev/null || true; } | head -40)
    diff_body=$({ git -C "$repo_dir" diff "${before_sha}..${sha}" 2>/dev/null || true; } | head -"$diff_lines")
  else
    range_label="${sha:0:12}"
    diff_stat=$({ git -C "$repo_dir" show --stat "$sha" 2>/dev/null || true; } | head -40)
    diff_body=$({ git -C "$repo_dir" show "$sha" 2>/dev/null || true; } | head -"$diff_lines")
  fi

  log "Running blocking Codex review on ${range_label} — \"${commit_title}\"..."

  set +e
  CODEX_HOME="$CODEX_HOME" codex exec \
    -m "$CODEX_MODEL" --output-schema "$SCHEMA" -o "$result_file" \
    -c model_reasoning_effort=xhigh \
    "You are reviewing work produced by an AI coding agent (Claude Code).

Range: ${range_label}
Tip commit title: ${commit_title}
Repo: ${repo_name}

--- DIFF STAT ---
${diff_stat}

--- DIFF ---
${diff_body}

Review focus:
1. Correctness — logic bugs, off-by-ones, wrong error handling, security issues
2. AGENTS.md invariants — if AGENTS.md exists at the repo root, flag any rule violations by rule ID
3. Tests — are tests added/updated? Do they exercise the new behaviour?
4. Multi-tenancy — any code that could leak data across tenants?
5. Convention — does new code follow existing patterns in the codebase?

Classify each finding as blocker / concern / nit.
Categorize each as: correctness, security, tenant_isolation, test_coverage, convention, or performance.
Set verdict to 'clean' only if there are no blockers and no concerns." \
    2>&1 | sed 's/^/[codex-gate] /'
  local codex_exit=$?
  set -e

  if [[ $codex_exit -ne 0 || ! -s "$result_file" ]]; then
    _codex_gate_inconclusive "$range_label" "$repo_name" "$closed_issues" \
      "Codex exited with code ${codex_exit} or produced no output — gate inconclusive."
    return $?
  fi

  local parsed verdict blockers concerns nits
  parsed=$(python3 "$LIB" codex-parse "$result_file" counts 2>/dev/null || printf 'unknown\t0\t0\t0')
  verdict=$(echo "$parsed"  | cut -f1)
  blockers=$(echo "$parsed" | cut -f2)
  concerns=$(echo "$parsed" | cut -f3)
  nits=$(echo "$parsed"     | cut -f4)

  if [[ "$verdict" == "unknown" ]]; then
    _codex_gate_inconclusive "$range_label" "$repo_name" "$closed_issues" \
      "Codex output could not be parsed or did not match the review schema — gate inconclusive."
    return $?
  fi

  log "────────────────────────────────────────────"
  log "Verdict: ${verdict} | blockers=${blockers} concerns=${concerns} nits=${nits}"
  log "Review: ${result_file}"
  log "────────────────────────────────────────────"

  local findings_md
  findings_md=$(python3 "$LIB" codex-parse "$result_file" findings 2>/dev/null \
    || echo "*(could not render findings)*")

  if [[ "$blockers" -gt 0 ]]; then
    [[ -n "${RALPH_ITER:-}" && "$RALPH_ITER" != "resume" ]] && _state_update_iter "$RALPH_ITER" "blocked" \
      "verdict=$verdict" "blockers=$blockers" "concerns=$concerns" "nits=$nits" 2>/dev/null || true

    log "GATE FAILED: ${blockers} blocker(s). Reopening issues for rework."
    local header="## Codex Review — BLOCKED

Reviewer: codex (${ACCOUNT}) | Range: \`${range_label}\` | Repo: ${repo_name}

$findings_md"

    for n in $closed_issues; do
      gh issue reopen "$n" --repo "$CORE_REPO" || true
      gh issue edit "$n" --repo "$CORE_REPO" --add-label ready-for-agent || true
      gh issue comment "$n" --repo "$CORE_REPO" --body "$header" || true
    done

    log "Reopened: $closed_issues — will retry next iteration."
    _CODEX_REVIEW_VERDICT="blocked"
    return 1
  fi

  if [[ $(( concerns + nits )) -gt 0 ]]; then
    local severity_note="concerns=${concerns}, nits=${nits}"
    local header="## Codex Review — Passed (${severity_note})

Reviewer: codex (${ACCOUNT}) | Range: \`${range_label}\` | Repo: ${repo_name}

$findings_md"

    for n in $closed_issues; do
      gh issue comment "$n" --repo "$CORE_REPO" --body "$header" || true
    done
  fi

  [[ -n "${RALPH_ITER:-}" && "$RALPH_ITER" != "resume" ]] && _state_update_iter "$RALPH_ITER" "done" \
    "verdict=${verdict:-clean}" "blockers=${blockers:-0}" "concerns=${concerns:-0}" "nits=${nits:-0}" 2>/dev/null || true

  _CODEX_REVIEW_VERDICT="$verdict"
  return 0
}

# ── Stream formatter ─────────────────────────────────────────────────────────

_write_formatter() {
  cat > "$1" <<'PYEOF'
import sys, json, datetime

RESET  = "\033[0m";  BOLD   = "\033[1m";  DIM    = "\033[2m"
CYAN   = "\033[36m"; YELLOW = "\033[33m"; GREEN  = "\033[32m"
RED    = "\033[31m"; BLUE   = "\033[34m"

def ts():
    return f"{DIM}{datetime.datetime.now().strftime('%H:%M:%S')}{RESET}"

for raw in sys.stdin:
    raw = raw.strip()
    if not raw:
        continue
    try:
        ev = json.loads(raw)
    except json.JSONDecodeError:
        print(raw, flush=True)
        continue

    t = ev.get("type", "")

    if t == "assistant":
        for block in ev.get("message", {}).get("content", []):
            if block.get("type") == "text":
                text = block["text"].strip()
                if text:
                    lines = text.splitlines()
                    print(f"{ts()} {CYAN}{BOLD}[claude]{RESET} {lines[0]}", flush=True)
                    for line in lines[1:]:
                        print(f"         {line}", flush=True)
            elif block.get("type") == "tool_use":
                name  = block.get("name", "?")
                inp   = block.get("input", {})
                label = inp.get("command") or inp.get("file_path") or inp.get("path") or ""
                if len(label) > 80:
                    label = label[:77] + "…"
                print(f"{ts()} {YELLOW}{BOLD}[tool  ]{RESET} {BOLD}{name}{RESET}  {DIM}{label}{RESET}", flush=True)

    elif t == "tool_result":
        for block in ev.get("content", []):
            if block.get("type") == "text":
                txt = block["text"].strip()
                low = txt.lower()
                if "error" in low or "traceback" in low or "failed" in low:
                    for line in txt.splitlines()[:8]:
                        print(f"{ts()} {RED}{BOLD}[error ]{RESET} {line}", flush=True)

    elif t == "result":
        subtype  = ev.get("subtype", "")
        cost     = ev.get("cost_usd")
        turns    = ev.get("num_turns", "?")
        cost_str = f"  ${cost:.4f}" if isinstance(cost, (int, float)) else ""
        if subtype == "error_during_execution":
            print(f"{ts()} {RED}{BOLD}[result]{RESET} ERROR: {ev.get('error','unknown')}", flush=True)
        else:
            print(f"{ts()} {GREEN}{BOLD}[result]{RESET} {subtype}  turns={turns}{cost_str}", flush=True)

    elif t == "system" and ev.get("subtype") == "init":
        sid = ev.get("session_id", "?")[:8]
        print(f"{ts()} {BLUE}{BOLD}[init  ]{RESET} session={sid}…", flush=True)
PYEOF
}

# ── Run journal ──────────────────────────────────────────────────────────────

J_RUN_ID=""
J_START_TS=0

_journal_finalize() {
  [[ -z "${J_RUN_ID:-}" ]] && return 0
  local _elapsed=$(( $(date +%s) - ${J_START_TS:-$(date +%s)} ))
  python3 "$LIB" journal-write \
    "$RUN_DIR" "$J_RUN_ID" \
    "${J_COMMAND:-once}" "${J_ISSUE:-}" "${J_PRD:-}" "${J_ALLOW_RISKY:-0}" \
    "${J_ROUTE:-}" "${J_BRANCH:-}" "${J_BEFORE_HEAD:-}" "${J_AFTER_HEAD:-${J_BEFORE_HEAD:-}}" \
    "${JOURNAL_PREFLIGHT_DECISION:-NOT_RUN}" "${JOURNAL_PREFLIGHT_WARNINGS:-}" \
    "${J_LOG_PATH:-}" "${J_REVIEW_RESULT:-}" "${J_REVIEW_FILE:-}" \
    "${J_FINAL_STATUS:-cancelled}" "$_elapsed" "${J_USAGE_EXHAUSTED:-0}" \
    --resume-hints "${J_RESUME_HINTS:-null}" --resumed-from "${J_RESUMED_FROM:-}" \
    2>/dev/null || true
  log "Journal written: $RUN_DIR/run-${J_RUN_ID}.md"
