#!/bin/bash
# ralph — global AFK agent runner
# Auto-detects account from CWD. Works from any repo root.
#
# Usage:
#   ralph once              # one iteration
#   ralph loop [--max N]    # loop until no issues (default max 10)
#   ralph check             # verify auth + account routing
#   ralph review <sha> <n>  # manual post-commit review
#   RALPH_MODEL=opus ralph once
#
# ── Architecture decisions (earned the hard way) ──────────────────────────────
#
# STDOUT IS THE TERMINAL. Do NOT use `exec > >(tee ...)` or fd redirection.
# VS Code's pty emulator + process substitution + set -eo pipefail = instant
# silent death (EPIPE/EIO, no output, no error). The working pattern is:
#   - log() prints to stdout and appends to $LOOP_LOG as a side-channel
#   - The `once` subprocess output (claude formatter) also goes to stdout
#   - No ANSI scroll regions, no background tick — just sequential log lines
#
# set -eo pipefail HAZARDS:
#   - `[[ cond ]] && action` on its own line → returns 1 if cond is false → death
#     Always use `if/fi` or add `|| true`
#   - `ls *.glob | wc -l` → ls returns nonzero on no match → pipefail kills it
#     Always use `find ... | wc -l` instead
#   - `(( x++ ))` when x=0 → arithmetic evaluates to 0 → exit 1
#     Always use `(( x++ )) || true`
#   - `printf` to a broken pipe → EPIPE → death
#     log() has `2>/dev/null || true` on file write
#
# ─────────────────────────────────────────────────────────────────────────────

set -eo pipefail
[[ "${RALPH_VERBOSE:-0}" == "1" ]] && set -x

_RALPH_CRASH_LOG="/tmp/ralph-crash-$$.log"
trap 'echo "[ralph CRASH] line $LINENO: exit $? — cmd: $BASH_COMMAND" >> "$_RALPH_CRASH_LOG"' ERR

# ── Detect repo root ──────────────────────────────────────────────────────────
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || { echo "[ralph] not in a git repo"; exit 1; }

# ── Account resolution ────────────────────────────────────────────────────────
ACCOUNTS_FILE="$HOME/.ralph/accounts.toml"

_flatten_toml() {
  python3 -c "
import sys, re
section = ''
for line in open(sys.argv[1]):
    line = line.strip()
    if not line or line.startswith('#'):
        continue
    m = re.match(r'\[(.+)\]', line)
    if m:
        section = m.group(1) + '.'
        continue
    if '=' in line:
        print(section + line)
" "$1"
}

_load_account() {
  local name="$1"
  ACCOUNT="$name"
  CLAUDE_CONFIG_DIR="$HOME/.claude"
  CODEX_HOME="$HOME/.codex"
  GH_CMD="gh"
  local gh_host="" gh_config_dir="" found=0

  while IFS= read -r line; do
    local key="${line%%=*}"
    local val="${line#*=}"
    key=$(echo "$key" | xargs)
    val=$(echo "$val" | xargs | tr -d '"' | sed "s|^~|$HOME|")
    case "$key" in
      "accounts.${name}.path")              found=1 ;;
      "accounts.${name}.claude_config_dir") CLAUDE_CONFIG_DIR="$val" ;;
      "accounts.${name}.codex_home")        CODEX_HOME="$val" ;;
      "accounts.${name}.gh_host")           gh_host="$val" ;;
      "accounts.${name}.gh_config_dir")     gh_config_dir="$val" ;;
    esac
  done < <(_flatten_toml "$ACCOUNTS_FILE")

  if [[ "$found" -eq 0 ]]; then
    return 1
  fi

  if [[ -n "$gh_host" ]]; then
    GH_CMD="GH_HOST=$gh_host gh"
    export GH_HOST="$gh_host"
  elif [[ -n "$gh_config_dir" ]]; then
    GH_CMD="GH_CONFIG_DIR=$gh_config_dir gh"
    export GH_CONFIG_DIR="$gh_config_dir"
  fi
}

_resolve_account() {
  # Priority 1: env var override
  if [[ -n "${RALPH_ACCOUNT:-}" ]]; then
    _load_account "$RALPH_ACCOUNT" || { echo "[ralph] RALPH_ACCOUNT='$RALPH_ACCOUNT' not found in $ACCOUNTS_FILE"; exit 1; }
    return
  fi

  # Priority 2: config file path match (longest prefix wins)
  if [[ -f "$ACCOUNTS_FILE" ]]; then
    local best_name="" best_len=0
    while IFS= read -r line; do
      local key="${line%%=*}"
      local val="${line#*=}"
      key=$(echo "$key" | xargs)
      val=$(echo "$val" | xargs | tr -d '"' | sed "s|^~|$HOME|")
      if [[ "$key" == accounts.*.path ]]; then
        local name="${key#accounts.}"
        name="${name%.path}"
        if [[ "$REPO_ROOT" == "$val"/* || "$REPO_ROOT" == "$val" ]]; then
          if (( ${#val} > best_len )); then
            best_name="$name"
            best_len=${#val}
          fi
        fi
      fi
    done < <(_flatten_toml "$ACCOUNTS_FILE")

    if [[ -n "$best_name" ]]; then
      _load_account "$best_name"
      return
    fi
  fi

  # Priority 3: default (single-account, no config needed)
  ACCOUNT="default"
  CLAUDE_CONFIG_DIR="$HOME/.claude"
  CODEX_HOME="$HOME/.codex"
  GH_CMD="gh"
}

_resolve_account
export CLAUDE_CONFIG_DIR
export CODEX_HOME

# ── Detect REPO slug from remote URL ─────────────────────────────────────────
remote_url=$(git -C "$REPO_ROOT" remote get-url origin 2>/dev/null) || { echo "[ralph] no origin remote"; exit 1; }
# handles: https://host/ORG/REPO  and  git@host:ORG/REPO.git
REPO=$(echo "$remote_url" | sed -E 's|.*[:/]([^/]+/[^/]+)\.git$|\1|; s|.*[:/]([^/]+/[^/]+)$|\1|')

MODEL="${RALPH_MODEL:-claude-opus-4-6}"
SCHEMA="$HOME/.claude/review-schema.json"

_R="\033[0m"; _BOLD="\033[1m"
_RALPH="\033[34m"   # blue   — ralph orchestrator
_WARN="\033[33m"    # yellow — warnings
_ERR="\033[31m"     # red    — errors / blockers
_OK="\033[32m"      # green  — success / clean
_DIM="\033[2m"      # dim    — timestamps

log() {
  local msg
  msg=$(printf "${_RALPH}${_BOLD}[ralph]${_R} ${_DIM}$(date '+%H:%M:%S')${_R} %s\n" "$*")
  printf '%s\n' "$msg"
  [[ -n "${LOOP_LOG:-}" ]] && printf '%s\n' "$msg" >> "$LOOP_LOG" 2>/dev/null || true
}
warn() { printf "${_WARN}${_BOLD}[ralph]${_R} ${_DIM}$(date '+%H:%M:%S')${_R} ${_WARN}WARN${_R}  %s\n" "$*" >&2; }
die()  { printf "${_ERR}${_BOLD}[ralph]${_R} ${_DIM}$(date '+%H:%M:%S')${_R} ${_ERR}ERROR${_R} %s\n" "$*" >&2; exit 1; }

_gh_comment() {
  local issue="$1" body="$2"
  local tmp; tmp=$(mktemp /tmp/ralph-body-XXXXXX.md)
  printf '%s' "$body" > "$tmp"
  eval "$GH_CMD issue comment \"$issue\" --repo \"$REPO\" --body-file \"$tmp\"" || true
  rm -f "$tmp"
}

_gh_reopen_for_rework() {
  local issue="$1" body="$2"
  eval "$GH_CMD issue reopen \"$issue\" --repo \"$REPO\"" || true
  eval "$GH_CMD issue edit \"$issue\" --repo \"$REPO\" --add-label ready-for-agent" || true
  _gh_comment "$issue" "$body"
}

# ── State + footer libraries ─────────────────────────────────────────────────
source "$HOME/.ralph/lib/state.sh"
source "$HOME/.ralph/lib/footer.sh"

# ── Subcommand dispatch ───────────────────────────────────────────────────────
CMD="${1:-help}"
shift || true

case "$CMD" in

# ─────────────────────────────────────────────────────────────────────────────
once)
  log "account : $ACCOUNT  (CLAUDE_CONFIG_DIR=$CLAUDE_CONFIG_DIR)"
  log "model   : $MODEL"
  log "repo    : $REPO_ROOT  →  $REPO"
  log "branch  : $(git -C "$REPO_ROOT" branch --show-current)"

  before_head=$(git -C "$REPO_ROOT" rev-parse HEAD)
  log "head    : $before_head"

  echo "$before_head" > /tmp/.ralph_pre_session_head

  before_open=$(eval "$GH_CMD issue list --repo \"$REPO\" --state open \
    --label ready-for-agent --json number --jq '.[].number'" | sort -u)

  if [[ -z "$before_open" ]]; then
    log "No ready-for-agent issues. Nothing to do."
    exit 0
  fi

  log "open: $(echo "$before_open" | tr '\n' ' ')"

  issues=$(eval "$GH_CMD issue list --repo \"$REPO\" --state open \
    --label ready-for-agent --json number,title,body,comments")
  commits=$(git -C "$REPO_ROOT" log -n 5 --format="%h %ad %s" --date=short)

  GLOBAL_PROMPT="$HOME/.ralph/prompt.md"
  REPO_PROMPT="$REPO_ROOT/ralph/prompt.md"
  [[ -f "$GLOBAL_PROMPT" ]] || die "~/.ralph/prompt.md not found"
  prompt=$(cat "$GLOBAL_PROMPT")
  [[ -f "$REPO_PROMPT" ]] && prompt="$prompt

---

$(cat "$REPO_PROMPT")"

  mkdir -p "$REPO_ROOT/ralph/logs"
  ts=$(date +%Y%m%dT%H%M%S)
  # always write raw JSONL (full record); formatter output goes to screen only
  raw_log="$REPO_ROOT/ralph/logs/session-${ts}.jsonl"

  log "Starting claude ($MODEL) — raw log: $raw_log"
  start_ts=$(date +%s)

  cd "$REPO_ROOT"

  export RALPH_SKIP_CODEX=1

  # Footer state: mark iteration as implementing (issue TBD until claude finishes)
  if [[ -n "${RALPH_ITER:-}" ]]; then
    _first_issue=$(echo "$before_open" | head -1)
    _first_title=$(eval "$GH_CMD issue view \"$_first_issue\" --repo \"$REPO\" --json title --jq '.title'" 2>/dev/null | head -c 28 || echo "")
    _state_update_iter "$RALPH_ITER" "implementing" "issue_number=$_first_issue" "issue_title=$_first_title"
  fi

  _claude_stream() {
    claude \
      --model "$MODEL" \
      --permission-mode bypassPermissions \
      --print \
      --verbose \
      --output-format stream-json \
      --no-session-persistence \
      "Previous commits:
$commits

Open AFK issues:
$issues

$prompt"
  }

  # Write formatter to a temp file so python3 reads stdin from the pipe, not the heredoc
  _fmt_py=$(mktemp /tmp/ralph-fmt-XXXXXX)
  mv "$_fmt_py" "${_fmt_py}.py"
  _fmt_py="${_fmt_py}.py"
  trap 'rm -f "$_fmt_py"' EXIT INT TERM
  cat > "$_fmt_py" <<'PYEOF'
import sys, json, datetime

RESET  = "\033[0m";  BOLD   = "\033[1m";  DIM    = "\033[2m"
CYAN   = "\033[36m"  # claude text
YELLOW = "\033[33m"  # tool calls
GREEN  = "\033[32m"  # success / result
RED    = "\033[31m"  # errors / blockers
BLUE   = "\033[34m"  # init / system
MAGENTA= "\033[35m"  # (reserved for codex prefix outside this script)

def ts():
    return f"{DIM}{datetime.datetime.now().strftime('%H:%M:%S')}{RESET}"

for raw in sys.stdin:
    raw = raw.strip()
    if not raw:
        continue
    try:
        ev = json.loads(raw)
    except json.JSONDecodeError:
        print(raw, flush=True)
        continue

    t = ev.get("type", "")

    if t == "assistant":
        for block in ev.get("message", {}).get("content", []):
            if block.get("type") == "text":
                text = block["text"].strip()
                if text:
                    # print multi-line claude text with prefix on first line only
                    lines = text.splitlines()
                    print(f"{ts()} {CYAN}{BOLD}[claude]{RESET} {lines[0]}", flush=True)
                    for line in lines[1:]:
                        print(f"         {line}", flush=True)
            elif block.get("type") == "tool_use":
                name  = block.get("name", "?")
                inp   = block.get("input", {})
                label = inp.get("command") or inp.get("file_path") or inp.get("path") or ""
                if len(label) > 80:
                    label = label[:77] + "…"
                print(f"{ts()} {YELLOW}{BOLD}[tool  ]{RESET} {BOLD}{name}{RESET}  {DIM}{label}{RESET}", flush=True)

    elif t == "tool_result":
        for block in ev.get("content", []):
            if block.get("type") == "text":
                txt = block["text"].strip()
                low = txt.lower()
                if "error" in low or "traceback" in low or "failed" in low:
                    for line in txt.splitlines()[:8]:
                        print(f"{ts()} {RED}{BOLD}[error ]{RESET} {line}", flush=True)

    elif t == "result":
        subtype  = ev.get("subtype", "")
        cost     = ev.get("cost_usd")
        turns    = ev.get("num_turns", "?")
        cost_str = f"  ${cost:.4f}" if isinstance(cost, (int, float)) else ""
        if subtype == "error_during_execution":
            print(f"{ts()} {RED}{BOLD}[result]{RESET} ERROR: {ev.get('error','unknown')}", flush=True)
        else:
            print(f"{ts()} {GREEN}{BOLD}[result]{RESET} {subtype}  turns={turns}{cost_str}", flush=True)

    elif t == "system" and ev.get("subtype") == "init":
        sid = ev.get("session_id", "?")[:8]
        print(f"{ts()} {BLUE}{BOLD}[init  ]{RESET} session={sid}…", flush=True)
PYEOF

  # always tee raw JSONL to disk; pipe through formatter for screen
  _fmt_stream() { python3 -u "$_fmt_py"; }
  _claude_stream | tee "$raw_log" | _fmt_stream

  elapsed=$(( $(date +%s) - start_ts ))
  log "Agent finished in ${elapsed}s — log: $raw_log"

  after_head=$(git -C "$REPO_ROOT" rev-parse HEAD)
  after_open=$(eval "$GH_CMD issue list --repo \"$REPO\" --state open \
    --label ready-for-agent --json number --jq '.[].number'" | sort -u)

  closed_issues=$(comm -23 <(echo "$before_open") <(echo "$after_open"))

  if [[ -z "$closed_issues" ]]; then
    log "No issues closed this iteration."
    [[ -n "${RALPH_ITER:-}" ]] && _state_update_iter "$RALPH_ITER" "done" "verdict=no_close"
    exit 0
  fi

  log "Closed: $closed_issues"

  # Footer state: update with actual closed issue and mark reviewing
  if [[ -n "${RALPH_ITER:-}" ]]; then
    _closed_n=$(echo "$closed_issues" | head -1)
    _closed_title=$(eval "$GH_CMD issue view \"$_closed_n\" --repo \"$REPO\" --json title --jq '.title'" 2>/dev/null | head -c 28 || echo "")
    _state_update_iter "$RALPH_ITER" "reviewing" "issue_number=$_closed_n" "issue_title=$_closed_title" "sha=${after_head:0:8}" "commits=1"
  fi

  if [[ "$before_head" == "$after_head" ]]; then
    warn "Issue(s) closed but HEAD did not move. Reopening."
    for n in $closed_issues; do
      _gh_reopen_for_rework "$n" "Reopened: agent closed issue without committing. Rework required."
    done
    die "Reopened $closed_issues — no commit made."
  fi

  log "New commit: $(git -C "$REPO_ROOT" rev-parse HEAD)"
  git -C "$REPO_ROOT" show --stat HEAD | sed 's/^/         /'

  # ── Blocking Codex review gate ───────────────────────────────────────────────
  commit_title=$(git -C "$REPO_ROOT" log -1 --format="%s")
  mkdir -p "$REPO_ROOT/ralph/reviews"
  ts=$(date +%Y%m%dT%H%M%S)
  result_file="$REPO_ROOT/ralph/reviews/review-${ts}-${after_head:0:8}.json"

  log "Running blocking Codex review on ${after_head:0:12} — \"${commit_title}\"..."

  diff_stat=$(git -C "$REPO_ROOT" show --stat "$after_head" 2>/dev/null | head -40 || true)
  diff_body=$(git -C "$REPO_ROOT" show "$after_head" 2>/dev/null | head -400 || true)

  set +e
  CODEX_HOME="$CODEX_HOME" codex exec \
    --output-schema "$SCHEMA" \
    -o "$result_file" \
    -c model_reasoning_effort=xhigh \
    "You are reviewing a commit produced by an AI coding agent (Claude Code).

Commit: ${after_head}
Title: ${commit_title}
Repo: $(basename "$REPO_ROOT")

--- DIFF STAT ---
${diff_stat}

--- DIFF ---
${diff_body}

Review focus:
1. Correctness — logic bugs, off-by-ones, wrong error handling, security issues
2. AGENTS.md invariants — if AGENTS.md exists at the repo root, flag any rule violations by rule ID
3. Tests — are tests added/updated? Do they exercise the new behaviour?

Classify each finding as blocker / concern / nit.
Set verdict to 'clean' only if there are no blockers and no concerns." \
    2>&1 | sed 's/^/[codex-gate] /'
  codex_exit=$?
  set -e

  if [[ $codex_exit -ne 0 || ! -s "$result_file" ]]; then
    warn "Codex exited $codex_exit or no output — gate inconclusive. Proceeding."
    [[ -n "${RALPH_ITER:-}" ]] && _state_update_iter "$RALPH_ITER" "done" "verdict=inconclusive"
  else
    verdict=$(python3 -c "import json; d=json.load(open('$result_file')); print(d.get('verdict','unknown'))" 2>/dev/null || echo "unknown")
    blockers=$(python3 -c "import json; d=json.load(open('$result_file')); print(sum(1 for i in d.get('issues',[]) if i.get('severity')=='blocker'))" 2>/dev/null || echo 0)
    concerns=$(python3 -c "import json; d=json.load(open('$result_file')); print(sum(1 for i in d.get('issues',[]) if i.get('severity')=='concern'))" 2>/dev/null || echo 0)
    nits=$(python3 -c "import json; d=json.load(open('$result_file')); print(sum(1 for i in d.get('issues',[]) if i.get('severity')=='nit'))" 2>/dev/null || echo 0)

    log "────────────────────────────────────────────"
    log "Verdict: ${verdict} | blockers=${blockers} concerns=${concerns} nits=${nits}"
    log "Review: ${result_file}"
    log "────────────────────────────────────────────"

    findings_md=$(python3 -c "
import json
d = json.load(open('$result_file'))
lines = ['**Verdict:** ' + d.get('verdict','?'), '', '**Summary:** ' + d.get('summary','')]
issues = d.get('issues', [])
if issues:
    lines += ['', '### Findings', '']
    for i in issues:
        loc = (' (\`' + i['file'] + ((':' + str(i['line'])) if 'line' in i else '') + '\`)') if 'file' in i else ''
        lines.append('- **[' + i['severity'] + ']** ' + i['description'] + loc)
else:
    lines.append('No findings.')
print('\n'.join(lines))
")

    actionable=$(( blockers + concerns ))

    if [[ "$actionable" -gt 0 ]]; then
      # Footer state: blocked
      [[ -n "${RALPH_ITER:-}" ]] && _state_update_iter "$RALPH_ITER" "blocked" \
        "verdict=$verdict" "blockers=$blockers" "concerns=$concerns" "nits=$nits"

      log "GATE FAILED: ${blockers} blocker(s), ${concerns} concern(s). Reopening issues for rework."

      header="## Codex Review — BLOCKED

Reviewer: codex (${ACCOUNT} account) | Commit: \`${after_head:0:12}\`

$findings_md"

      for n in $closed_issues; do
        _gh_reopen_for_rework "$n" "$header"
      done

      log "Reopened: $closed_issues — will retry next iteration."
      exit 0
    fi

    # Clean or nits-only — post informational comment on closed issues
    if [[ "$nits" -gt 0 ]]; then
      header="## Codex Review — Passed (nits only)

Reviewer: codex (${ACCOUNT} account) | Commit: \`${after_head:0:12}\`

$findings_md"

      for n in $closed_issues; do
        _gh_comment "$n" "$header"
      done
    fi
  fi

  # Footer state: done (clean or nits-only)
  [[ -n "${RALPH_ITER:-}" ]] && _state_update_iter "$RALPH_ITER" "done" \
    "verdict=${verdict:-clean}" "blockers=${blockers:-0}" "concerns=${concerns:-0}" "nits=${nits:-0}"

  log "Done. Issue(s) closed and review passed."
  ;;

# ─────────────────────────────────────────────────────────────────────────────
loop)
  MAX=10
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --max) MAX="$2"; shift 2 ;;
      *) echo "Usage: ralph loop [--max N]"; exit 1 ;;
    esac
  done

  # ── Preflight: fail fast with a visible error before footer takes over ──
  if ! eval "$GH_CMD api /user --jq .login" >/dev/null 2>&1; then
    printf "${_ERR}${_BOLD}[ralph]${_R} Preflight FAILED: cannot authenticate to GitHub.\n" >&2
    printf "${_ERR}        Run: gh auth login -h %s${_R}\n" "${GH_HOST:-github.com}" >&2
    exit 1
  fi
  if ! command -v claude >/dev/null 2>&1; then
    printf "${_ERR}${_BOLD}[ralph]${_R} Preflight FAILED: 'claude' not found in PATH.${_R}\n" >&2
    exit 1
  fi

  LOOP_LOG="/tmp/ralph-loop-$$.log"
  export LOOP_LOG
  : > "$LOOP_LOG"

  _state_init "$MAX"

  _loop_cleanup() {
    _state_cleanup
    if [[ -f "$LOOP_LOG" ]]; then
      printf '\n\033[2m[ralph] full log: %s\033[0m\n' "$LOOP_LOG"
    fi
  }
  trap '_loop_cleanup' EXIT
  trap '_loop_cleanup; exit 130' INT
  trap '_loop_cleanup; exit 143' TERM

  log "Loop start — max $MAX, model: $MODEL, repo: $REPO"
  log "══════════════════════════════════════"

  success=0; failed=0

  for (( i=1; i<=MAX; i++ )); do
    open_count=$(eval "$GH_CMD issue list --repo \"$REPO\" --state open \
      --label ready-for-agent --json number --jq '.[].number'" 2>/dev/null \
      | grep -c . || true)

    if [[ "$open_count" -eq 0 ]]; then
      log "No ready-for-agent issues. Loop done after $((i-1)) iteration(s)."
      break
    fi

    _state_update_iter "$i" "starting"

    log "── Iteration $i / $MAX ($open_count open) ──"

    if RALPH_ITER="$i" RALPH_STATE_DIR="$RALPH_STATE_DIR" "$0" once; then
      (( success++ )) || true
    else
      exit_code=$?
      (( failed++ )) || true
      if [[ $exit_code -eq 130 ]]; then
        log "Interrupted (Ctrl-C) — stopping loop."
        break
      elif [[ $exit_code -eq 1 ]]; then
        log "once exited with error — stopping loop."
        break
      fi
    fi

    if [[ $i -lt $MAX ]]; then
      log "Cooldown 5s… (Ctrl-C to stop)"
      sleep 5 &
      wait $! || { log "Interrupted during cooldown."; break; }
    fi
  done

  log "══════════════════════════════════════"
  log "Done. Succeeded: $success  Failed: $failed"

  remaining=$(eval "$GH_CMD issue list --repo \"$REPO\" --state open \
    --label ready-for-agent --json number,title \
    --jq '.[] | \"  #\(.number) \(.title)\"'" 2>/dev/null || true)

  if [[ -n "$remaining" ]]; then
    log "Still open:"
    printf '%s\n' "$remaining"
    printf '%s\n' "$remaining" >> "$LOOP_LOG" 2>/dev/null || true
  else
    log "All ready-for-agent issues resolved."
  fi
  ;;

# ─────────────────────────────────────────────────────────────────────────────
review)
  # Usage: ralph review <sha> [sha ...] -- <issue> [issue ...]
  # Single SHA:     ralph review 8f624ae 78
  # Multiple SHAs:  ralph review eda9cbb 977832d -- 79
  [[ $# -lt 2 ]] && { echo "Usage: ralph review <sha> [sha ...] -- <issue> [issue ...]"; exit 1; }

  shas=(); issues_arr=(); saw_sep=0
  for arg in "$@"; do
    if [[ "$arg" == "--" ]]; then
      saw_sep=1
    elif [[ $saw_sep -eq 1 || "$arg" =~ ^[0-9]+$ ]]; then
      issues_arr+=("$arg")
    else
      shas+=("$arg")
    fi
  done

  [[ ${#shas[@]} -eq 0 ]]    && { log "no SHAs given"; exit 1; }
  [[ ${#issues_arr[@]} -eq 0 ]] && { log "no issue numbers given"; exit 1; }

  mkdir -p "$REPO_ROOT/ralph/logs" "$REPO_ROOT/ralph/reviews"

  _do_review() {
    local sha="$1"
    local ts; ts=$(date +%Y%m%dT%H%M%S)
    local log_file="$REPO_ROOT/ralph/logs/review-${ts}-${sha:0:8}.log"
    local result_file="$REPO_ROOT/ralph/reviews/review-${ts}-${sha:0:8}.json"
    local commit_title; commit_title=$(git -C "$REPO_ROOT" log -1 --format="%s" "$sha" 2>/dev/null || echo "unknown")
    local diff_stat diff_body
    diff_stat=$(git -C "$REPO_ROOT" show --stat "$sha" 2>/dev/null | head -40 || true)
    diff_body=$(git -C "$REPO_ROOT" show "$sha" 2>/dev/null | head -400 || true)

    log "Reviewing ${sha:0:12} — $commit_title"

    set +e
    CODEX_HOME="$CODEX_HOME" codex exec \
      --output-schema "$SCHEMA" \
      -o "$result_file" \
      "You are reviewing a commit from an AI coding agent.
Commit: $sha  Title: $commit_title  Repo: $REPO
Issues: $(IFS=,; echo "${issues_arr[*]}")

--- DIFF STAT ---
${diff_stat}

--- DIFF ---
${diff_body}

Focus: correctness, AGENTS.md rule violations (by ID), tests.
Classify each finding as blocker / concern / nit.
Set verdict to 'clean' only if no blockers and no concerns." \
      2>&1 | tee "$log_file" | sed 's/^/[codex] /'
    local codex_exit=$?
    set -e

    if [[ $codex_exit -ne 0 || ! -s "$result_file" ]]; then
      log "Codex exited $codex_exit or no output — log: $log_file"
      return 1
    fi

    local verdict blockers concerns nits
    verdict=$(python3 -c "import json; d=json.load(open('$result_file')); print(d.get('verdict','unknown'))" 2>/dev/null || echo "unknown")
    blockers=$(python3 -c "import json; d=json.load(open('$result_file')); print(sum(1 for i in d.get('issues',[]) if i.get('severity')=='blocker'))" 2>/dev/null || echo 0)
    concerns=$(python3 -c "import json; d=json.load(open('$result_file')); print(sum(1 for i in d.get('issues',[]) if i.get('severity')=='concern'))" 2>/dev/null || echo 0)
    nits=$(python3 -c "import json; d=json.load(open('$result_file')); print(sum(1 for i in d.get('issues',[]) if i.get('severity')=='nit'))" 2>/dev/null || echo 0)

    log "────────────────────────────────────────────"
    log "Verdict: ${verdict} | blockers=${blockers} concerns=${concerns} nits=${nits}"
    log "Saved: ${result_file}"
    log "────────────────────────────────────────────"

    local findings_md
    findings_md=$(python3 -c "
import json
d = json.load(open('$result_file'))
lines = ['**Verdict:** ' + d.get('verdict','?'), '', '**Summary:** ' + d.get('summary','')]
issues = d.get('issues', [])
if issues:
    lines += ['', '### Findings', '']
    for i in issues:
        loc = (' (\`' + i.get('file','') + ((':' + str(i['line'])) if 'line' in i else '') + '\`)') if i.get('file') else ''
        lines.append('- **[' + i['severity'] + ']** ' + i['description'] + loc)
else:
    lines.append('No findings.')
print('\n'.join(lines))
")

    local header="## Codex review of \`${sha:0:12}\`
Reviewer: codex ($ACCOUNT account) | $commit_title"
    local actionable=$(( blockers + concerns ))

    for n in "${issues_arr[@]}"; do
      if [[ $actionable -gt 0 ]]; then
        _gh_reopen_for_rework "$n" "${header}

Reopened — fix blockers/concerns before merging.

${findings_md}"
      else
        _gh_comment "$n" "${header}

${findings_md}"
      fi
    done
  }

  for sha in "${shas[@]}"; do
    _do_review "$sha" || log "Review of ${sha:0:12} failed — continuing"
  done
  ;;

# ─────────────────────────────────────────────────────────────────────────────
init)
  log "Initializing ralph in $REPO_ROOT ($ACCOUNT)"

  # 1 — prompt.md
  PROMPT_FILE="$REPO_ROOT/ralph/prompt.md"
  if [[ -f "$PROMPT_FILE" ]]; then
    log "ralph/prompt.md already exists — skipping"
  else
    mkdir -p "$REPO_ROOT/ralph"
    printf "What is the test command for this repo? (e.g. pytest, npm test): "
    read -r test_cmd
    cat > "$PROMPT_FILE" <<EOF
# Repo-specific additions for $(basename "$REPO_ROOT")

## Test command

\`\`\`bash
$test_cmd
\`\`\`

Run from repo root. All tests must pass before committing.
EOF
    log "Created ralph/prompt.md"
  fi

  # 2 — gitignore runtime dirs
  EXCLUDE_FILE="$REPO_ROOT/.git/info/exclude"
  mkdir -p "$(dirname "$EXCLUDE_FILE")"
  for entry in "ralph/logs/" "ralph/reviews/"; do
    if ! grep -qF "$entry" "$EXCLUDE_FILE" 2>/dev/null; then
      echo "$entry" >> "$EXCLUDE_FILE"
      log "Added $entry to .git/info/exclude"
    fi
  done
  mkdir -p "$REPO_ROOT/ralph/logs" "$REPO_ROOT/ralph/reviews"

  # 3 — GitHub labels
  for label in "ready-for-agent" "needs-triage"; do
    if eval "$GH_CMD label list --repo \"$REPO\" --json name --jq '.[].name'" 2>/dev/null | grep -qF "$label"; then
      log "Label '$label' already exists"
    else
      eval "$GH_CMD label create \"$label\" --repo \"$REPO\" --color \"0075ca\" --description \"\"" 2>/dev/null \
        && log "Created label '$label'" \
        || warn "Could not create label '$label' — check gh auth"
    fi
  done

  log "Done. Run 'ralph check' to verify."
  ;;

# ─────────────────────────────────────────────────────────────────────────────
check)
  echo ""
  echo "ralph check — $REPO_ROOT"
  echo "══════════════════════════════════"
  echo "account   : $ACCOUNT"
  echo "config    : ${ACCOUNTS_FILE}$([ -f "$ACCOUNTS_FILE" ] && echo " (loaded)" || echo " (not found, using defaults)")"
  echo "repo      : $REPO"
  echo "claude    : $CLAUDE_CONFIG_DIR"
  echo "codex     : $CODEX_HOME"
  echo "gh        : $GH_CMD"
  echo "model     : $MODEL  (RALPH_MODEL to override)"
  echo ""

  echo -n "claude auth : "
  result=$(bash -c "CLAUDE_CONFIG_DIR='$CLAUDE_CONFIG_DIR' claude --print 'reply: OK'" 2>&1 | head -1) || true
  echo "$result" | grep -qi "OK" && echo "✓" || echo "✗  $result"

  echo -n "gh auth     : "
  eval "$GH_CMD api user --jq '.login'" 2>&1 && true

  echo -n "codex auth  : "
  CODEX_HOME="$CODEX_HOME" codex --version 2>&1 | head -1

  PROMPT_FILE="$REPO_ROOT/ralph/prompt.md"
  echo ""
  echo -n "prompt.md   : "
  [[ -f "$PROMPT_FILE" ]] && echo "✓  $PROMPT_FILE" || echo "✗  MISSING — create ralph/prompt.md"
  echo ""
  ;;

# ─────────────────────────────────────────────────────────────────────────────
*)
  cat <<'EOF'
ralph — AFK agent runner

  ralph init              make this repo ralph-ready (first-time setup)
  ralph once              one iteration
  ralph loop [--max N]    loop until done (default max 10)
  ralph check             verify auth + routing
  ralph review <sha> [sha..] -- <n> [n..]  manual post-commit review

env:
  RALPH_MODEL=<model>     override model (default: claude-opus-4-6)
  RALPH_VERBOSE=1         shell trace

account routing:
  Config:    ~/.ralph/accounts.toml (multi-account)
  Override:  RALPH_ACCOUNT=<name>
  Default:   bare gh + ~/.claude + ~/.codex (no config needed)
EOF
  ;;
esac
