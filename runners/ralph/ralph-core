# ── Retention sweep ──────────────────────────────────────────────────────────

_prune_stale() {
  local prune_output
  prune_output=$(python3 "$LIB" prune-stale "$RUN_DIR" "$SCHED_DIR" "${RALPH_RETENTION_DAYS:-30}" 2>/dev/null || true)

  # Handle schedule cancellations
  while IFS=$'\t' read -r tag job_id backend backend_id; do
    if [[ "$tag" == "PRUNE_SCHED" && "$backend" != "none" ]]; then
      _sched_cancel "$job_id" "$backend" "$backend_id" 2>/dev/null || true
    fi
  done <<< "$prune_output"

  local pruned_line
  pruned_line=$(echo "$prune_output" | grep '^PRUNED' || true)
  if [[ -n "$pruned_line" ]]; then
    local _pr _ps
    IFS=$'\t' read -r _ _pr _ps <<< "$pruned_line"
    if (( _pr + _ps > 0 )); then
      log "Pruned: $_pr run journal(s), $_ps schedule(s) older than ${RALPH_RETENTION_DAYS:-30}d"
    fi
  fi
}

# ── Resume helpers ───────────────────────────────────────────────────────────

_resume_prechecks() {
  local run_id="$1"
  local run_json="$RUN_DIR/run-${run_id}.json"

  [[ ! -f "$run_json" ]] && { log "resume FAIL: journal not found: $run_json"; return 1; }

  local final_status
  final_status=$(python3 "$LIB" json-get "$run_json" final_status 2>/dev/null || echo "")
  case "$final_status" in
    usage_exhausted|agent_failed|standby) ;;
    *) log "resume FAIL: final_status is '${final_status:-<empty>}' — not resumable"; return 1 ;;
  esac

  local r_issue r_branch r_expected_head r_route r_repo_dir
  IFS=$'\t' read -r r_issue r_branch r_expected_head < \
    <(python3 "$LIB" json-get "$run_json" resume_hints.issue resume_hints.branch resume_hints.expected_head 2>/dev/null)
  r_route=$(python3 "$LIB" json-get "$run_json" route 2>/dev/null || echo "")
  r_repo_dir=$(_repo_dir "$r_route")

  [[ -z "$r_branch" ]] && { log "resume FAIL: resume_hints.branch is empty"; return 1; }
  [[ -z "$r_repo_dir" || ! -d "$r_repo_dir/.git" ]] && { log "resume FAIL: sub-repo not found for route '${r_route}'"; return 1; }

  if ! git -C "$r_repo_dir" show-ref --verify --quiet "refs/heads/${r_branch}" 2>/dev/null; then
    log "resume FAIL: branch '${r_branch}' does not exist in $(basename "$r_repo_dir")"
    return 1
  fi

  local current_head=""
  if [[ -n "$r_expected_head" ]]; then
    current_head=$(git -C "$r_repo_dir" rev-parse "refs/heads/${r_branch}" 2>/dev/null || echo "")
    if [[ "$current_head" != "$r_expected_head" ]]; then
      log "resume FAIL: HEAD of '${r_branch}' is ${current_head:0:12} but expected ${r_expected_head:0:12}"
      return 1
    fi
  fi

  local dirty
  dirty=$(git -C "$r_repo_dir" status --porcelain 2>/dev/null || echo "ERR")
  if [[ -n "$dirty" ]]; then
    if [[ -n "$r_expected_head" && "$current_head" == "$r_expected_head" ]]; then
      log "resume: worktree has uncommitted changes from interrupted run — continuing"
    else
      log "resume FAIL: worktree is dirty and HEAD doesn't match expected — commit or stash first"
      return 1
    fi
  fi

  if [[ -n "$r_issue" ]]; then
    local i_data
    i_data=$(gh issue view "$r_issue" --repo "$CORE_REPO" \
      --json number,title,body,labels,state 2>/dev/null) || { log "resume FAIL: could not fetch issue #${r_issue}"; return 1; }
    local i_title i_body i_labels i_state _if_out
    _if_out=$(echo "$i_data" | python3 "$LIB" issue-fields 2>/dev/null || printf '\t\t')
    IFS=$'\t' read -r i_title i_labels i_state <<< "$(head -1 <<< "$_if_out")"
    i_body=$(tail -n +2 <<< "$_if_out")
    local i_result i_status i_reason
    i_result=$(_evaluate_issue "$r_issue" "$i_title" "$i_body" "$i_labels" "$i_state")
    IFS='|' read -r i_status _ i_reason <<< "$i_result"
    if [[ "$i_status" != "eligible" ]]; then
      log "resume FAIL: issue #${r_issue} is no longer eligible — ${i_status}${i_reason:+: $i_reason}"
      return 1
    fi
  fi

  local r_allow_risky
  r_allow_risky=$(python3 "$LIB" json-get "$run_json" target_flags.allow_risky 2>/dev/null || echo "0")

  RESUME_ISSUE="$r_issue"
  RESUME_BRANCH="$r_branch"
  RESUME_ROUTE="$r_route"
  RESUME_REPO_DIR="$r_repo_dir"
  RESUME_ALLOW_RISKY="$r_allow_risky"

  log "resume  : pre-checks passed (issue #${r_issue}, branch ${r_branch})"
  return 0
}

# ── Usage / help ─────────────────────────────────────────────────────────────

_usage() {
  cat <<'EOF'
ralph-core — AFK agent runner for discount-genie-core multi-repo workspace

USAGE
  ./ralph/ralph-core <subcommand> [flags]

SUBCOMMANDS
  init              workspace setup (branches, labels, dirs)
  once [flags]      run one agent iteration
  loop [flags]      loop until no ready issues (default max 10)
  resume RUN_ID     retry a previous interrupted run
  schedule          manage scheduled runs (list / show / logs / cancel)
  ping [flags]      minimal Claude session (keeps usage counter alive)
  check             verify auth, routing, and sub-repos

ENV
  RALPH_FEATURE_BRANCH=feature/x  target feature branch
  RALPH_SKIP_CODEX=1               skip Codex review gate
  RALPH_MODEL=claude-sonnet-4-6    override Claude model (default: claude-opus-4-6)
  RALPH_EFFORT=high                override Claude effort (default: medium)
  RALPH_CODEX_MODEL=o3             override Codex review model (default: gpt-5.5)
  RALPH_DIFF_LINES=800             max diff lines sent to Codex review (default 800)
  RALPH_RETENTION_DAYS=30          prune journals/schedules older than N days (default 30)
  RALPH_GATE_STRICT=1              fail-closed on inconclusive Codex reviews
  RALPH_VERBOSE=1                  shell trace
EOF
}

_usage_once() {
  cat <<'EOF'
ralph-core once — run one agent iteration

FLAGS
  --issue N                  target a specific issue by number
  --prd N                    filter queue to PRD #N children
  --allow-risky              allow risky issues
  --schedule "YYYY-MM-DD HH:MM"  defer execution
EOF
}

_usage_loop() {
  cat <<'EOF'
ralph-core loop — loop until no ready-for-agent issues remain

FLAGS
  --max N                    maximum iterations (default: 10; 5 when --prd)
  --prd N                    filter queue to PRD #N children
  --allow-risky              allow risky issues
  --schedule "YYYY-MM-DD HH:MM"  defer loop start
EOF
}

_usage_resume() {
  cat <<'EOF'
ralph-core resume — retry a previous interrupted or exhausted run

USAGE
  ./ralph/ralph-core resume RUN_ID [--schedule "YYYY-MM-DD HH:MM"]
  ./ralph/ralph-core resume list
EOF
}

# ── Subcommand dispatch ──────────────────────────────────────────────────────
CMD="${1:-}"
shift || true

if [[ -z "$CMD" || "$CMD" == "--help" || "$CMD" == "-h" || "$CMD" == "help" ]]; then
  _usage
  exit 0
fi

case "$CMD" in

# ─────────────────────────────────────────────────────────────────────────────
once)
  ONCE_ISSUE="" ONCE_PRD="" ONCE_ALLOW_RISKY=0 ONCE_SCHEDULE=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h) _usage_once; exit 0 ;;
      --issue)   [[ $# -lt 2 || -z "${2:-}" ]] && { echo "error: --issue requires N" >&2; exit 1; }; ONCE_ISSUE="$2"; shift 2 ;;
      --prd)     [[ $# -lt 2 || -z "${2:-}" ]] && { echo "error: --prd requires N" >&2; exit 1; }; ONCE_PRD="$2"; shift 2 ;;
      --allow-risky) ONCE_ALLOW_RISKY=1; shift ;;
      --schedule) [[ $# -lt 2 || -z "${2:-}" ]] && { echo "error: --schedule requires datetime" >&2; exit 1; }; ONCE_SCHEDULE="$2"; shift 2 ;;
      -*) echo "error: unknown flag: $1" >&2; _usage_once; exit 1 ;;
      *)  echo "error: unexpected argument: $1" >&2; _usage_once; exit 1 ;;
    esac
  done

  log "account : $ACCOUNT"
  log "model   : $MODEL"
  log "core    : $CORE_ROOT → $CORE_REPO"

  # ── Scheduled run (no specific issue): defer to fire time ────────────────
  if [[ -n "$ONCE_SCHEDULE" && -z "$ONCE_ISSUE" ]]; then
    log "schedule: $ONCE_SCHEDULE — running global creation-time preflight"
    _sched_parsed=$(python3 "$LIB" parse-dt "$ONCE_SCHEDULE" 2>&1) || die "$_sched_parsed"
    _sched_epoch=$(echo "$_sched_parsed" | cut -d' ' -f1)
    _sched_iso=$(echo "$_sched_parsed"   | cut -d' ' -f2)

    RALPH_PREFLIGHT_ALLOW_FUTURE_USAGE=1 RALPH_PREFLIGHT_SCHEDULE_EPOCH="$_sched_epoch"
    if ! _preflight "" "" "$ONCE_ALLOW_RISKY"; then
      unset RALPH_PREFLIGHT_ALLOW_FUTURE_USAGE RALPH_PREFLIGHT_SCHEDULE_EPOCH
      exit 1
    fi
    unset RALPH_PREFLIGHT_ALLOW_FUTURE_USAGE RALPH_PREFLIGHT_SCHEDULE_EPOCH

    _sched_stored_cmd="once${ONCE_PRD:+ --prd $ONCE_PRD}"
    [[ "$ONCE_ALLOW_RISKY" == "1" ]] && _sched_stored_cmd+=" --allow-risky"
    _sched_flags_json=$(python3 "$LIB" json-build "prd=${ONCE_PRD:-null}" "allow_risky=$([[ "$ONCE_ALLOW_RISKY" == "1" ]] && echo true || echo false)")
    if ! _schedule_create "$_sched_stored_cmd" "$_sched_flags_json" "$ONCE_ALLOW_RISKY" \
      "$_sched_iso" "$_sched_epoch" "$JOURNAL_PREFLIGHT_DECISION" "${JOURNAL_PREFLIGHT_WARNINGS:-}"; then
      die "schedule: failed to register OS job for $_job_id"
    fi

    log "────────────────────────────────────────────"
    log "Scheduled  : $_job_id"
    log "  Command  : $_sched_stored_cmd"
    log "  Run at   : $ONCE_SCHEDULE"
    log "  Backend  : ${_SCHED_BACKEND}"
    log "  Inspect  : ./ralph/ralph-core schedule show $_job_id"
    log "────────────────────────────────────────────"
    exit 0
  fi

  # Issue selection
  if [[ -n "$ONCE_ISSUE" ]]; then
    issue_data=$(gh issue view "$ONCE_ISSUE" --repo "$CORE_REPO" \
      --json number,title,body,labels,state 2>/dev/null) || die "Issue #$ONCE_ISSUE not found"
    _if_out=$(echo "$issue_data" | python3 "$LIB" issue-fields 2>/dev/null || printf '\t\t')
    IFS=$'\t' read -r _i_title _i_labels _i_state <<< "$(head -1 <<< "$_if_out")"
    _i_body=$(tail -n +2 <<< "$_if_out")
    _i_result=$(_evaluate_issue "$ONCE_ISSUE" "$_i_title" "$_i_body" "$_i_labels" "$_i_state")
    IFS='|' read -r _i_status _i_route _i_reason <<< "$_i_result"
    [[ "$_i_status" == "prd_issue" ]] && { log "SKIP: #$ONCE_ISSUE is a PRD issue"; exit 1; }
    [[ "$_i_status" != "eligible" ]] && { log "SKIP: #$ONCE_ISSUE not eligible — ${_i_status}${_i_reason:+: $_i_reason}"; exit 1; }
    picked="${ONCE_ISSUE}|${_i_title}|${_i_route}"
  elif [[ -n "$ONCE_PRD" ]]; then
    picked=$(_pick_issue_from_prd "$ONCE_PRD") || { log "No eligible children of PRD #$ONCE_PRD."; exit 0; }
  else
    picked=$(_pick_issue) || { log "No unblocked ready-for-agent issues."; [[ -n "${RALPH_ITER:-}" ]] && exit 3 || exit 0; }
  fi

  IFS='|' read -r ISSUE_NUM ISSUE_TITLE ISSUE_ROUTE <<< "$picked"
  WORK_DIR=$(_repo_dir "$ISSUE_ROUTE")
  WORK_REPO=$(_repo_name "$ISSUE_ROUTE")

  # ── Scheduled run (--issue path) ────────────────────────────────────────
  if [[ -n "$ONCE_SCHEDULE" && -n "$ONCE_ISSUE" ]]; then
    log "schedule: $ONCE_SCHEDULE — running creation-time preflight"
    _sched_parsed=$(python3 "$LIB" parse-dt "$ONCE_SCHEDULE" 2>&1) || die "$_sched_parsed"
    _sched_epoch=$(echo "$_sched_parsed" | cut -d' ' -f1)
    _sched_iso=$(echo "$_sched_parsed"   | cut -d' ' -f2)

    RALPH_PREFLIGHT_ALLOW_FUTURE_USAGE=1 RALPH_PREFLIGHT_SCHEDULE_EPOCH="$_sched_epoch"
    if ! _preflight "$ISSUE_NUM" "$ISSUE_ROUTE" "$ONCE_ALLOW_RISKY"; then
      unset RALPH_PREFLIGHT_ALLOW_FUTURE_USAGE RALPH_PREFLIGHT_SCHEDULE_EPOCH
      exit 1
    fi
    unset RALPH_PREFLIGHT_ALLOW_FUTURE_USAGE RALPH_PREFLIGHT_SCHEDULE_EPOCH

    _sched_stored_cmd="once${ONCE_ISSUE:+ --issue $ONCE_ISSUE}${ONCE_PRD:+ --prd $ONCE_PRD}"
    [[ "$ONCE_ALLOW_RISKY" == "1" ]] && _sched_stored_cmd+=" --allow-risky"
    _sched_flags_json=$(python3 "$LIB" json-build \
      "issue=${ONCE_ISSUE:-null}" "prd=${ONCE_PRD:-null}" "route=${ISSUE_ROUTE:-null}" \
      "allow_risky=$([[ "$ONCE_ALLOW_RISKY" == "1" ]] && echo true || echo false)")
    if ! _schedule_create "$_sched_stored_cmd" "$_sched_flags_json" "$ONCE_ALLOW_RISKY" \
      "$_sched_iso" "$_sched_epoch" "$JOURNAL_PREFLIGHT_DECISION" "${JOURNAL_PREFLIGHT_WARNINGS:-}"; then
      die "schedule: failed to register OS job for $_job_id"
    fi

    log "────────────────────────────────────────────"
    log "Scheduled  : $_job_id"
    log "  Command  : $_sched_stored_cmd"
    log "  Run at   : $ONCE_SCHEDULE"
    log "  Backend  : ${_SCHED_BACKEND}"
    log "────────────────────────────────────────────"
    exit 0
  fi

  log "picked  : #$ISSUE_NUM ($ISSUE_ROUTE) — $ISSUE_TITLE"
  log "workdir : $WORK_DIR"

  # ── Journal init ──────────────────────────────────────────────────────────
  mkdir -p "$RUN_DIR"
  J_RUN_ID="$(date +%Y%m%dT%H%M%S)-$(python3 "$LIB" gen-id)"
  J_START_TS=$(date +%s)
  J_COMMAND="once${ONCE_ISSUE:+ --issue $ONCE_ISSUE}${ONCE_PRD:+ --prd $ONCE_PRD}"
  J_ISSUE="$ISSUE_NUM" J_PRD="${ONCE_PRD:-}" J_ALLOW_RISKY="$ONCE_ALLOW_RISKY"
  J_ROUTE="$ISSUE_ROUTE" J_BRANCH="" J_BEFORE_HEAD="" J_AFTER_HEAD=""
  J_LOG_PATH="" J_REVIEW_RESULT="" J_REVIEW_FILE=""
  J_FINAL_STATUS="cancelled" J_USAGE_EXHAUSTED=0
  J_RESUME_HINTS="" J_RESUMED_FROM="${RALPH_RESUME_FROM:-}" J_FMT_PY=""
  JOURNAL_PREFLIGHT_DECISION="NOT_RUN"

  _once_cleanup() {
    _journal_finalize
    [[ -z "${RALPH_ITER:-}" ]] && _lock_release
    rm -f "${J_FMT_PY:-}"
  }
  trap '_once_cleanup' EXIT
  trap '
    if [[ -n "${J_ISSUE:-}" && -n "${before_head:-}" ]]; then
      J_FINAL_STATUS="agent_failed"
      J_RESUME_HINTS=$(python3 "$LIB" resume-hints "$J_ISSUE" "$(git -C "$WORK_DIR" branch --show-current 2>/dev/null || echo "${current_branch:-}")" "$(git -C "$WORK_DIR" rev-parse HEAD 2>/dev/null || echo "${before_head:-}")" 2>/dev/null || echo "null")
    fi
    _once_cleanup; exit 130
  ' INT
  trap '
    if [[ -n "${J_ISSUE:-}" && -n "${before_head:-}" ]]; then
      J_FINAL_STATUS="agent_failed"
      J_RESUME_HINTS=$(python3 "$LIB" resume-hints "$J_ISSUE" "$(git -C "$WORK_DIR" branch --show-current 2>/dev/null || echo "${current_branch:-}")" "$(git -C "$WORK_DIR" rev-parse HEAD 2>/dev/null || echo "${before_head:-}")" 2>/dev/null || echo "null")
    fi
    _once_cleanup; exit 143
  ' TERM

  # ── Preflight + lock ──────────────────────────────────────────────────────
  if [[ -z "${RALPH_ITER:-}" ]]; then
    if ! _preflight "$ISSUE_NUM" "$ISSUE_ROUTE" "$ONCE_ALLOW_RISKY"; then
      J_FINAL_STATUS="preflight_nogo"; exit 2
    fi
    _lock_acquire "once${ONCE_ISSUE:+ --issue $ONCE_ISSUE}${ONCE_PRD:+ --prd $ONCE_PRD}"
  else
    if ! _preflight_issue_soft "$ISSUE_NUM" "$ISSUE_ROUTE" "$ONCE_ALLOW_RISKY"; then
      J_FINAL_STATUS="preflight_nogo"; exit 2
    fi
  fi

  current_branch=$(_ensure_feature_branch "$WORK_DIR")
  log "branch  : $current_branch"
  J_BRANCH="$current_branch"

  before_head=$(git -C "$WORK_DIR" rev-parse HEAD)
  log "head    : $before_head"
  J_BEFORE_HEAD="$before_head"
  echo "$before_head" > /tmp/.ralph_pre_session_head

  # Fetch issue details
  issue_json=$(gh issue view "$ISSUE_NUM" --repo "$CORE_REPO" --json body,comments)
  issue_body=$(echo "$issue_json" | python3 "$LIB" json-stdin body 2>/dev/null || echo "")
  issue_comments=$(echo "$issue_json" | python3 "$LIB" format-comments 2>/dev/null || echo "No prior comments.")

  other_issues=$(gh issue list --repo "$CORE_REPO" --state open \
    --label ready-for-agent --json number,title \
    --jq '[.[] | select(.number != '"$ISSUE_NUM"') | "- #\(.number): \(.title)"] | join("\n")')

  commits=$(git -C "$WORK_DIR" log -n 10 --format="%h %ad %s" --date=short)

  # Build prompt
  GLOBAL_PROMPT="$HOME/.ralph/prompt.md"
  WORKSPACE_PROMPT="$RALPH_DIR/prompt.md"
  if [[ -f "$GLOBAL_PROMPT" ]]; then
    prompt=$(cat "$GLOBAL_PROMPT")
    [[ -f "$WORKSPACE_PROMPT" ]] && prompt="$prompt

---

$(cat "$WORKSPACE_PROMPT")"
  elif [[ -f "$WORKSPACE_PROMPT" ]]; then
    prompt=$(cat "$WORKSPACE_PROMPT")
  else
    die "no prompt.md found"
  fi

  # Log setup
  mkdir -p "$RALPH_DIR/logs"
  ts=$(date +%Y%m%dT%H%M%S)
  raw_log="$RALPH_DIR/logs/session-${ts}-issue${ISSUE_NUM}.jsonl"
  J_LOG_PATH="$raw_log"

  log "Starting claude ($MODEL) in $WORK_REPO — raw log: $raw_log"

  if [[ -n "${RALPH_ITER:-}" && "$RALPH_ITER" != "resume" ]]; then
    _state_update_iter "$RALPH_ITER" "implementing" \
      "issue_number=$ISSUE_NUM" "issue_title=${ISSUE_TITLE:0:28}" 2>/dev/null || true
  fi

  before_open=$(gh issue list --repo "$CORE_REPO" --state open \
    --label ready-for-agent --json number --limit 100 --jq '.[].number' | sort -u)

  _claude_stream() {
    cd "$WORK_DIR"
    claude \
      --model "$MODEL" --effort "$EFFORT" \
      --permission-mode bypassPermissions --print \
      --output-format stream-json --verbose --no-session-persistence \
      "IMPORTANT: You are running AFK — no human is present. You MUST commit and \
close the issue yourself. Do not ask \"should I commit?\", \"want me to commit?\", \
or \"ready to commit when you say the word\". Stage files and run git commit \
directly. Waiting for confirmation will hang this session with no one to answer.

You are implementing issue #${ISSUE_NUM}: ${ISSUE_TITLE}
Target repo: ${WORK_REPO}

## Issue #${ISSUE_NUM}

${issue_body}

## Review comments

${issue_comments}

## Other open issues (for awareness — do NOT implement these)

${other_issues:-None.}

## Recent commits in ${WORK_REPO}

${commits}

${prompt}"
  }

  J_FMT_PY=$(mktemp /tmp/ralph-core-fmt-XXXXXX)
  _write_formatter "$J_FMT_PY"
  _fmt_stream() { python3 -u "$J_FMT_PY"; }

  _claude_exit=0
  local _caller_skip_codex="${RALPH_SKIP_CODEX:-0}"
  export RALPH_SKIP_CODEX=1
  _claude_stream | tee "$raw_log" | _fmt_stream || {
    _pipe_exits=("${PIPESTATUS[@]}")
    _claude_exit=${_pipe_exits[0]:-0}
    [[ ${_pipe_exits[1]:-0} -ne 0 ]] && warn "tee exited ${_pipe_exits[1]} — raw log may be incomplete"
    [[ ${_pipe_exits[2]:-0} -ne 0 && ${_pipe_exits[2]:-0} -ne 141 ]] && log "WARNING: formatter exited ${_pipe_exits[2]}"
    [[ $_claude_exit -eq 141 ]] && { warn "claude exited 141 (SIGPIPE) — treating as succeeded"; _claude_exit=0; }
    export RALPH_SKIP_CODEX="$_caller_skip_codex"
  }
  export RALPH_SKIP_CODEX="$_caller_skip_codex"

  elapsed=$(( $(date +%s) - ${J_START_TS:-$(date +%s)} ))
  log "Agent finished in ${elapsed}s (exit ${_claude_exit}) — log: $raw_log"

  if ! after_head=$(git -C "$WORK_DIR" rev-parse HEAD 2>/dev/null); then
    warn "git rev-parse HEAD failed — aborting"
    J_FINAL_STATUS="agent_failed"
    J_RESUME_HINTS=$(python3 "$LIB" resume-hints "$ISSUE_NUM" "$current_branch" "$before_head" 2>/dev/null || echo "null")
    exit 1
  fi
  J_AFTER_HEAD="$after_head"

  # Usage exhaustion detection
  if [[ -f "$raw_log" ]]; then
    _exhaust=$(python3 "$LIB" journal-scan "$raw_log" 2>&1) || { _exhaust="ok"; }
    if [[ "$_exhaust" == "exhausted" ]]; then
      J_USAGE_EXHAUSTED=1
      J_FINAL_STATUS="usage_exhausted"
      _hint_branch=$(git -C "$WORK_DIR" branch --show-current 2>/dev/null || echo "")
      J_RESUME_HINTS=$(python3 "$LIB" resume-hints "$ISSUE_NUM" "$_hint_branch" "${after_head:-$before_head}" 2>/dev/null || echo "null")
      warn "Usage exhaustion detected — resume with: ./ralph/ralph-core resume $J_RUN_ID"
    fi
  fi

  if [[ $_claude_exit -ne 0 && "$J_USAGE_EXHAUSTED" -eq 0 ]]; then
    warn "claude exited ${_claude_exit} — marking run as agent_failed"
    J_FINAL_STATUS="agent_failed"
    _hint_branch=$(git -C "$WORK_DIR" branch --show-current 2>/dev/null || echo "")
    J_RESUME_HINTS=$(python3 "$LIB" resume-hints "$ISSUE_NUM" "$_hint_branch" "${after_head:-$before_head}" 2>/dev/null || echo "null")
  fi

  if [[ "$J_USAGE_EXHAUSTED" -eq 1 || $_claude_exit -ne 0 ]]; then
    if [[ -n "${J_ISSUE:-}" ]] && echo "$before_open" | grep -qxF "$J_ISSUE"; then
      _cur_state=$(gh issue view "$J_ISSUE" --repo "$CORE_REPO" --json state --jq '.state' 2>/dev/null || echo "")
      if [[ "$_cur_state" == "CLOSED" ]]; then
        log "Issue #$J_ISSUE closed by Claude but run exhausted/failed — reopening"
        gh issue reopen "$J_ISSUE" --repo "$CORE_REPO" 2>/dev/null || true
        gh issue edit "$J_ISSUE" --repo "$CORE_REPO" --add-label "ready-for-agent" || true
      fi
    fi
    exit 1
  fi

  # Close detection
  after_open=$(gh issue list --repo "$CORE_REPO" --state open \
    --label ready-for-agent --json number --limit 100 --jq '.[].number' | sort -u)

  _all_closed=$(comm -23 <(printf '%s\n' "$before_open" | grep -v '^$' | sort -u) \
                          <(printf '%s\n' "$after_open"  | grep -v '^$' | sort -u) 2>/dev/null || true)

  # Scope to the target issue — ignore issues closed by external actors during the run
  closed_issues=""
  if printf '%s\n' "$_all_closed" | grep -qxF "$ISSUE_NUM" 2>/dev/null; then
    closed_issues="$ISSUE_NUM"
  fi

  if [[ -z "$closed_issues" && "$before_head" != "$after_head" ]]; then
    log "HEAD moved but issue not closed — closing #$ISSUE_NUM"
    gh issue close "$ISSUE_NUM" --repo "$CORE_REPO" \
      --comment "Closed by ralph-core: $(git -C "$WORK_DIR" log -1 --format='%s')" || true
    closed_issues="$ISSUE_NUM"
  fi

  if [[ -z "$closed_issues" ]]; then
    log "No issues closed this iteration."
    [[ -n "${RALPH_ITER:-}" && "$RALPH_ITER" != "resume" ]] && _state_update_iter "$RALPH_ITER" "done" "verdict=no_close" 2>/dev/null || true
    J_FINAL_STATUS="no_close"
    J_RESUME_HINTS=$(python3 "$LIB" resume-hints "$ISSUE_NUM" "$current_branch" "${after_head:-$before_head}" 2>/dev/null || echo "null")
    exit 0
  fi

  log "Closed: $closed_issues"

  if [[ -n "${RALPH_ITER:-}" && "$RALPH_ITER" != "resume" ]]; then
    _closed_n=$(echo "$closed_issues" | head -1)
    _state_update_iter "$RALPH_ITER" "reviewing" \
      "issue_number=$_closed_n" "sha=${after_head:0:8}" "commits=1" 2>/dev/null || true
  fi

  if [[ "$before_head" == "$after_head" ]]; then
    if [[ -n "${RALPH_RESUME_BEFORE_HEAD:-}" && "$RALPH_RESUME_BEFORE_HEAD" != "$before_head" ]]; then
      log "HEAD unchanged this session, but resume base differs — reviewing partial commits."
    else
      warn "Issue(s) closed but HEAD did not move — trusting agent closure."
      [[ -n "${RALPH_ITER:-}" && "$RALPH_ITER" != "resume" ]] && _state_update_iter "$RALPH_ITER" "done" "verdict=no_commit" 2>/dev/null || true
      J_FINAL_STATUS="no_commit"
      _unlock_downstream "$closed_issues"
      exit 0
    fi
  fi

  log "New commit in $WORK_REPO: $(git -C "$WORK_DIR" rev-parse HEAD)"
  git -C "$WORK_DIR" show --stat HEAD | sed 's/^/         /'

  _review_base="${RALPH_RESUME_BEFORE_HEAD:-$before_head}"
  if ! _run_codex_review "$WORK_DIR" "$after_head" "$closed_issues" "$_review_base"; then
    J_FINAL_STATUS="review_blocked"
    J_REVIEW_RESULT="${_CODEX_REVIEW_VERDICT:-blocked}"
    exit 0
  fi

  J_REVIEW_RESULT="${_CODEX_REVIEW_VERDICT:-clean}"
  [[ -f "${_CODEX_REVIEW_FILE:-}" ]] && J_REVIEW_FILE="$_CODEX_REVIEW_FILE"

  _unlock_downstream "$closed_issues"
  J_FINAL_STATUS="success"
  log "Done. Issue(s) closed and review passed."
  ;;

# ─────────────────────────────────────────────────────────────────────────────
loop)
  LOOP_MAX_EXPLICIT=0 MAX=10 LOOP_PRD="" LOOP_ALLOW_RISKY=0 LOOP_SCHEDULE=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h) _usage_loop; exit 0 ;;
      --max)     [[ $# -lt 2 ]] && { echo "error: --max requires N" >&2; exit 1; }; MAX="$2"; LOOP_MAX_EXPLICIT=1; shift 2 ;;
      --prd)     [[ $# -lt 2 ]] && { echo "error: --prd requires N" >&2; exit 1; }; LOOP_PRD="$2"; shift 2 ;;
      --allow-risky) LOOP_ALLOW_RISKY=1; shift ;;
      --schedule) [[ $# -lt 2 ]] && { echo "error: --schedule requires datetime" >&2; exit 1; }; LOOP_SCHEDULE="$2"; shift 2 ;;
      -*) echo "error: unknown flag: $1" >&2; _usage_loop; exit 1 ;;
      *)  echo "error: unexpected argument: $1" >&2; _usage_loop; exit 1 ;;
    esac
  done

  [[ "$LOOP_MAX_EXPLICIT" -eq 0 && -n "$LOOP_PRD" ]] && MAX=5

  _loop_prd_cand_count=0
  if [[ -n "$LOOP_PRD" ]]; then
    _loop_prd_cand_count=$(gh issue list --repo "$CORE_REPO" --state open \
      --label ready-for-agent --json number,title,labels,body --limit 100 2>/dev/null \
      | python3 "$LIB" prd-filter "$LOOP_PRD" 2>/dev/null | grep -co $'\x1e') || _loop_prd_cand_count=0
  fi

  _sched_parsed="" _sched_epoch="" _sched_iso=""
  if [[ -n "$LOOP_SCHEDULE" ]]; then
    _sched_parsed=$(python3 "$LIB" parse-dt "$LOOP_SCHEDULE" 2>&1) || die "$_sched_parsed"
    _sched_epoch=$(echo "$_sched_parsed" | cut -d' ' -f1)
    _sched_iso=$(echo "$_sched_parsed"   | cut -d' ' -f2)
    RALPH_PREFLIGHT_ALLOW_FUTURE_USAGE=1
    RALPH_PREFLIGHT_SCHEDULE_EPOCH="$_sched_epoch"
  fi

  _preflight "" "" "$LOOP_ALLOW_RISKY" "$_loop_prd_cand_count" || {
    unset RALPH_PREFLIGHT_ALLOW_FUTURE_USAGE RALPH_PREFLIGHT_SCHEDULE_EPOCH
    exit 2
  }
  unset RALPH_PREFLIGHT_ALLOW_FUTURE_USAGE RALPH_PREFLIGHT_SCHEDULE_EPOCH

  if [[ -n "$LOOP_SCHEDULE" ]]; then
    _sched_stored_cmd="loop${LOOP_PRD:+ --prd $LOOP_PRD} --max $MAX"
    [[ "$LOOP_ALLOW_RISKY" == "1" ]] && _sched_stored_cmd+=" --allow-risky"
    _sched_flags_json=$(python3 "$LIB" json-build \
      "prd=${LOOP_PRD:-null}" "max=$MAX" "allow_risky=$([[ "$LOOP_ALLOW_RISKY" == "1" ]] && echo true || echo false)")
    if ! _schedule_create "$_sched_stored_cmd" "$_sched_flags_json" "$LOOP_ALLOW_RISKY" \
      "$_sched_iso" "$_sched_epoch" "${JOURNAL_PREFLIGHT_DECISION:-GO}" "${JOURNAL_PREFLIGHT_WARNINGS:-}"; then
      die "schedule: failed to register OS job for $_job_id"
    fi
    log "────────────────────────────────────────────"
    log "Scheduled  : $_job_id"
    log "  Command  : $_sched_stored_cmd"
    log "  Run at   : $LOOP_SCHEDULE"
    log "  Backend  : ${_SCHED_BACKEND}"
    log "────────────────────────────────────────────"
    exit 0
  fi

  _lock_acquire "loop${LOOP_PRD:+ --prd $LOOP_PRD} --max $MAX"

  if type -t _state_init &>/dev/null; then
    _state_init "$MAX"
    _footer_setup
    _loop_cleanup() { _lock_release; _footer_teardown; _state_cleanup; }
    trap '_loop_cleanup' EXIT
    trap '_loop_cleanup; exit 130' INT
    trap '_loop_cleanup; exit 143' TERM
    trap '_footer_handle_winch' WINCH
  else
    trap '_lock_release' EXIT
    trap '_lock_release; exit 130' INT
    trap '_lock_release; exit 143' TERM
  fi

  [[ -n "$LOOP_PRD" ]] \
    && log "Loop start (PRD #$LOOP_PRD) — max $MAX, model: $MODEL" \
    || log "Loop start — max $MAX, model: $MODEL, core: $CORE_REPO"
  log "══════════════════════════════════════"

  success=0 failed=0 _prd_skip_nums=""

  for (( i=1; i<=MAX; i++ )); do
    if [[ -n "$LOOP_PRD" ]]; then
      prd_picked=$(_pick_issue_from_prd "$LOOP_PRD" "$_prd_skip_nums" 2>/dev/null) || {
        log "No eligible children of PRD #$LOOP_PRD. Loop done after $((i-1)) iteration(s)."
        break
      }
      IFS='|' read -r _prd_issue_num _ _ <<< "$prd_picked"

      type -t _state_update_iter &>/dev/null && _state_update_iter "$i" "starting" 2>/dev/null || true
      log "── Iteration $i / $MAX (PRD #$LOOP_PRD → issue #$_prd_issue_num) ──"

      if RALPH_ITER="$i" RALPH_STATE_DIR="${RALPH_STATE_DIR:-}" "$0" once --issue "$_prd_issue_num" $([[ "$LOOP_ALLOW_RISKY" == "1" ]] && echo --allow-risky); then
        (( success++ )) || true
      else
        exit_code=$?
        (( failed++ )) || true
        [[ $exit_code -eq 130 ]] && { log "Interrupted — stopping loop."; break; }
        [[ $exit_code -eq 2 ]] && { _prd_skip_nums="${_prd_skip_nums} ${_prd_issue_num}"; warn "preflight NO_GO for #$_prd_issue_num — skipping"; continue; }
        [[ $exit_code -eq 1 ]] && { warn "agent error for #$_prd_issue_num — stopping loop."; break; }
      fi
    else
      type -t _state_update_iter &>/dev/null && _state_update_iter "$i" "starting" 2>/dev/null || true
      log "── Iteration $i / $MAX ──"

      if RALPH_ITER="$i" RALPH_STATE_DIR="${RALPH_STATE_DIR:-}" "$0" once $([[ "$LOOP_ALLOW_RISKY" == "1" ]] && echo --allow-risky); then
        (( success++ )) || true
      else
        exit_code=$?
        [[ $exit_code -eq 130 ]] && { log "Interrupted — stopping loop."; break; }
        [[ $exit_code -eq 3 ]] && { log "No ready-for-agent issues. Loop done."; break; }
        (( failed++ )) || true
        [[ $exit_code -eq 2 ]] && { log "preflight NO_GO — stopping loop."; break; }
        [[ $exit_code -eq 1 ]] && { log "once exited with error — stopping loop."; break; }
      fi
    fi

    if [[ $i -lt $MAX ]]; then
      log "Cooldown 5s… (Ctrl-C to stop)"
      sleep 5 & wait $! || { log "Interrupted during cooldown."; break; }
    fi
  done

  log "══════════════════════════════════════"
  log "Done. Succeeded: $success  Failed: $failed"

  remaining=$(gh issue list --repo "$CORE_REPO" --state open \
    --label ready-for-agent --json number,title \
    --jq '.[] | "  #\(.number) \(.title)"' 2>/dev/null || true)
  [[ -n "$remaining" ]] && { log "Still open:"; echo "$remaining"; } || log "All resolved."

  _prune_stale
  ;;

# ─────────────────────────────────────────────────────────────────────────────
resume)
  if [[ "${1:-}" == "list" ]]; then
    python3 "$LIB" resume-list "$RUN_DIR"
    exit 0
  fi

  [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { _usage_resume; exit 0; }

  RESUME_RUN_ID="${1:-}"
  [[ -z "$RESUME_RUN_ID" ]] && { echo "error: resume requires RUN_ID" >&2; _usage_resume; exit 1; }
  shift || true

  RESUME_SCHEDULE=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h) _usage_resume; exit 0 ;;
      --schedule) [[ $# -lt 2 ]] && { echo "error: --schedule requires datetime" >&2; exit 1; }; RESUME_SCHEDULE="$2"; shift 2 ;;
      -*) echo "error: unknown flag: $1" >&2; exit 1 ;;
      *)  echo "error: unexpected arg: $1" >&2; exit 1 ;;
    esac
  done

  log "account : $ACCOUNT"
  log "model   : $MODEL"

  RESUME_ISSUE="" RESUME_BRANCH="" RESUME_ROUTE="" RESUME_REPO_DIR=""
  _resume_prechecks "$RESUME_RUN_ID" || exit 1

  if [[ -n "$RESUME_SCHEDULE" ]]; then
    _sched_parsed=$(python3 "$LIB" parse-dt "$RESUME_SCHEDULE" 2>&1) || die "$_sched_parsed"
    _sched_epoch=$(echo "$_sched_parsed" | cut -d' ' -f1)
    _sched_iso=$(echo "$_sched_parsed"   | cut -d' ' -f2)

    RALPH_PREFLIGHT_ALLOW_FUTURE_USAGE=1 RALPH_PREFLIGHT_SCHEDULE_EPOCH="$_sched_epoch"
    if ! _preflight "$RESUME_ISSUE" "$RESUME_ROUTE" "${RESUME_ALLOW_RISKY:-0}"; then
      unset RALPH_PREFLIGHT_ALLOW_FUTURE_USAGE RALPH_PREFLIGHT_SCHEDULE_EPOCH; exit 1
    fi
    unset RALPH_PREFLIGHT_ALLOW_FUTURE_USAGE RALPH_PREFLIGHT_SCHEDULE_EPOCH

    _sched_stored_cmd="resume $RESUME_RUN_ID"
    _sched_flags_json=$(python3 "$LIB" json-build "resume_run_id=$RESUME_RUN_ID" "allow_risky=$([[ "${RESUME_ALLOW_RISKY:-0}" == "1" ]] && echo true || echo false)")
    if ! _schedule_create "$_sched_stored_cmd" "$_sched_flags_json" "${RESUME_ALLOW_RISKY:-0}" \
      "$_sched_iso" "$_sched_epoch" "${JOURNAL_PREFLIGHT_DECISION:-GO}" "${JOURNAL_PREFLIGHT_WARNINGS:-}"; then
      die "schedule: failed to register OS job for $_job_id"
    fi
    log "────────────────────────────────────────────"
    log "Scheduled  : $_job_id  |  Resume: $RESUME_RUN_ID  |  Run at: $RESUME_SCHEDULE"
    log "────────────────────────────────────────────"
    exit 0
  fi

  log "resuming : issue #$RESUME_ISSUE on branch '$RESUME_BRANCH'"

  _preflight "$RESUME_ISSUE" "$RESUME_ROUTE" "${RESUME_ALLOW_RISKY:-0}" || exit 1
  _lock_acquire "resume $RESUME_RUN_ID"
  trap '_lock_release' EXIT
  trap '_lock_release; exit 130' INT
  trap '_lock_release; exit 143' TERM

  _current_branch=$(git -C "$RESUME_REPO_DIR" branch --show-current)
  if [[ "$_current_branch" != "$RESUME_BRANCH" ]]; then
    log "resume: checking out recorded branch '${RESUME_BRANCH}'"
    git -C "$RESUME_REPO_DIR" checkout "$RESUME_BRANCH" \
      || { log "resume FAIL: could not checkout '${RESUME_BRANCH}'"; exit 1; }
  fi

  RESUME_ORIGINAL_BEFORE_HEAD=$(python3 "$LIB" json-get "$RUN_DIR/run-${RESUME_RUN_ID}.json" before_head 2>/dev/null || echo "")

  _resume_once_args=(once --issue "$RESUME_ISSUE")
  [[ "${RESUME_ALLOW_RISKY:-0}" == "1" ]] && _resume_once_args+=(--allow-risky)
  set +e
  RALPH_ITER=resume RALPH_RESUME_FROM="$RESUME_RUN_ID" \
    RALPH_RESUME_BEFORE_HEAD="$RESUME_ORIGINAL_BEFORE_HEAD" \
    "$0" "${_resume_once_args[@]}"
  _resume_exit=$?
  set -e

  if [[ "$_resume_exit" -eq 0 ]]; then
    python3 "$LIB" update-status "$RUN_DIR/run-${RESUME_RUN_ID}.json" "resumed" 2>/dev/null \
      || warn "resume: could not update source journal status"
  fi
  exit "$_resume_exit"
  ;;

# ─────────────────────────────────────────────────────────────────────────────
run-scheduled)
  _RS_JOB_ID="${1:-}"
  [[ -z "$_RS_JOB_ID" ]] && die "run-scheduled: missing JOB_ID"
  [[ ! -f "$SCHED_DIR/${_RS_JOB_ID}.json" ]] && die "run-scheduled: schedule not found"

  _rs_meta=$(python3 "$LIB" sched-batch "$SCHED_DIR/${_RS_JOB_ID}.json" 2>/dev/null)
  _rs_status=$(sed -n '1p' <<< "$_rs_meta")
  _rs_run_at=$(sed -n '2p' <<< "$_rs_meta")
  _rs_stale_flag=$(sed -n '3p' <<< "$_rs_meta")
  _rs_log=$(sed -n '4p' <<< "$_rs_meta")
  _rs_cmd=$(sed -n '5p' <<< "$_rs_meta")
  _rs_allow_risky=$(sed -n '6p' <<< "$_rs_meta")
  _rs_issue_num=$(sed -n '7p' <<< "$_rs_meta")
  _rs_route=$(sed -n '8p' <<< "$_rs_meta")
  _rs_run_at_epoch=$(sed -n '9p' <<< "$_rs_meta")
  _rs_now_epoch=$(sed -n '10p' <<< "$_rs_meta")

  [[ "$_rs_status" != "pending" ]] && die "run-scheduled: status '$_rs_status' (expected pending)"

  if [[ -n "$_rs_run_at_epoch" && -n "$_rs_now_epoch" \
        && "$_rs_now_epoch" -lt "$(( _rs_run_at_epoch - 60 ))" ]]; then
    log "run-scheduled: $_RS_JOB_ID too early — skipping"
    exit 0
  fi

  if [[ "$_rs_stale_flag" == "1" ]]; then
    log "run-scheduled: $_RS_JOB_ID skipped (stale)"
    python3 "$LIB" sched-update "$SCHED_DIR" "$_RS_JOB_ID" "status=skipped"
    _rs_backend=$(python3 "$LIB" sched-get "$SCHED_DIR" "$_RS_JOB_ID" backend 2>/dev/null || echo "none")
    if [[ "$_rs_backend" != "none" ]]; then
      _rs_backend_id=$(python3 "$LIB" sched-get "$SCHED_DIR" "$_RS_JOB_ID" backend_id 2>/dev/null || echo "none")
      _sched_cancel "$_RS_JOB_ID" "$_rs_backend" "$_rs_backend_id" 2>/dev/null || true
    fi
    exit 0
  fi

  [[ -z "$_rs_log" ]] && die "run-scheduled: no log_path"
  [[ -z "$_rs_cmd" ]] && die "run-scheduled: no command"
  mkdir -p "$(dirname "$_rs_log")"

  JOURNAL_PREFLIGHT_DECISION="NO_GO" JOURNAL_PREFLIGHT_WARNINGS=""
  _rs_prev_cache_ttl="${RALPH_CLAUDE_AUTH_CACHE_TTL:-}"
  RALPH_CLAUDE_AUTH_CACHE_TTL=0
  if ! _preflight "${_rs_issue_num:-}" "${_rs_route:-}" "$_rs_allow_risky"; then
    RALPH_CLAUDE_AUTH_CACHE_TTL="${_rs_prev_cache_ttl}"
    _rs_pf_json=$(python3 "$LIB" json-build "decision=$JOURNAL_PREFLIGHT_DECISION" "warnings=${JOURNAL_PREFLIGHT_WARNINGS:-}")
    python3 "$LIB" sched-update "$SCHED_DIR" "$_RS_JOB_ID" "status=failed" --preflight-at-runtime-json "$_rs_pf_json"
    _rs_backend=$(python3 "$LIB" sched-get "$SCHED_DIR" "$_RS_JOB_ID" backend 2>/dev/null || echo "none")
    if [[ "$_rs_backend" != "none" ]]; then
      _rs_backend_id=$(python3 "$LIB" sched-get "$SCHED_DIR" "$_RS_JOB_ID" backend_id 2>/dev/null || echo "none")
      _sched_cancel "$_RS_JOB_ID" "$_rs_backend" "$_rs_backend_id" 2>/dev/null || true
    fi
    die "run-scheduled: runtime preflight NO_GO"
  fi
  RALPH_CLAUDE_AUTH_CACHE_TTL="${_rs_prev_cache_ttl}"

  _rs_pf_json=$(python3 "$LIB" json-build "decision=$JOURNAL_PREFLIGHT_DECISION" "warnings=${JOURNAL_PREFLIGHT_WARNINGS:-}")

  _rs_subcmd="${_rs_cmd%% *}"
  case "$_rs_subcmd" in
    once|loop|resume|ping) ;;
    *) die "run-scheduled: unknown subcommand '${_rs_subcmd}'" ;;
  esac

  python3 "$LIB" sched-update "$SCHED_DIR" "$_RS_JOB_ID" "status=running" "pid=$$" --preflight-at-runtime-json "$_rs_pf_json"
  log "run-scheduled: starting $_RS_JOB_ID — command: $_rs_cmd"

  _rs_before_ts=$(date +%s)
  _rs_exit=0
  # shellcheck disable=SC2086
  "$0" $_rs_cmd >> "$_rs_log" 2>&1 || _rs_exit=$?

  _rs_run_id=""
  while IFS= read -r _jf; do
    _jf_ts=$(stat -f%m "$_jf" 2>/dev/null || stat -c%Y "$_jf" 2>/dev/null || echo 0)
    if [[ "$_jf_ts" -ge "$_rs_before_ts" ]]; then
      _rs_run_id=$(python3 "$LIB" json-get "$_jf" run_id 2>/dev/null || echo "")
      break
    fi
  done < <(find "$RUN_DIR" -maxdepth 1 -name 'run-*.json' 2>/dev/null | sort -r)

  if [[ $_rs_exit -eq 0 ]]; then
    python3 "$LIB" sched-update "$SCHED_DIR" "$_RS_JOB_ID" "status=done" ${_rs_run_id:+"run_id=${_rs_run_id}"}
    log "run-scheduled: $_RS_JOB_ID completed"
  else
    python3 "$LIB" sched-update "$SCHED_DIR" "$_RS_JOB_ID" "status=failed" ${_rs_run_id:+"run_id=${_rs_run_id}"}
    warn "run-scheduled: $_RS_JOB_ID exited $_rs_exit"
  fi

  _rs_backend=$(python3 "$LIB" sched-get "$SCHED_DIR" "$_RS_JOB_ID" backend 2>/dev/null || echo "none")
  if [[ "$_rs_backend" != "none" ]]; then
    _rs_backend_id=$(python3 "$LIB" sched-get "$SCHED_DIR" "$_RS_JOB_ID" backend_id 2>/dev/null || echo "none")
    _sched_cancel "$_RS_JOB_ID" "$_rs_backend" "$_rs_backend_id" 2>/dev/null || true
    log "run-scheduled: $_RS_JOB_ID unloaded OS job ($_rs_backend)"
  fi
  ;;

# ─────────────────────────────────────────────────────────────────────────────
schedule)
  _SCHED_SUBCMD="${1:-}"; shift || true
  case "$_SCHED_SUBCMD" in
    list)   python3 "$LIB" sched-list "$SCHED_DIR" ;;
    show)   [[ -z "${1:-}" ]] && die "schedule show: missing JOB_ID"
            python3 "$LIB" sched-show "$SCHED_DIR" "$1" ;;
    logs)   [[ -z "${1:-}" ]] && die "schedule logs: missing JOB_ID"
            _sl_job_id="$1"; shift || true
            _sl_log=$(python3 "$LIB" sched-get "$SCHED_DIR" "$_sl_job_id" log_path 2>/dev/null || echo "")
            [[ -z "$_sl_log" ]] && die "schedule logs: no log_path"
            if [[ "${1:-}" == "--follow" ]]; then
              if [[ ! -f "$_sl_log" ]]; then
                _sl_run_at=$(python3 "$LIB" sched-get "$SCHED_DIR" "$_sl_job_id" run_at 2>/dev/null || echo "")
                printf "${_DIM}Waiting for ${_sl_job_id} to start${_sl_run_at:+ (scheduled: ${_sl_run_at})}…${_R}\n" >&2
                while [[ ! -f "$_sl_log" ]]; do
                  sleep 2
                done
                printf "${_OK}${_BOLD}Log appeared — streaming${_R}\n" >&2
              fi
              exec tail -f "$_sl_log"
            fi
            cat "$_sl_log" 2>/dev/null || echo "(log not yet created)" ;;
    cancel) [[ -z "${1:-}" ]] && die "schedule cancel: missing JOB_ID"
            _sc_job_id="$1"
            _sc_status=$(python3 "$LIB" sched-get "$SCHED_DIR" "$_sc_job_id" status 2>/dev/null || echo "")
            [[ "$_sc_status" == "cancelled" ]] && { warn "already cancelled"; exit 0; }
            if [[ "$_sc_status" == "running" ]]; then
              _sc_pid=$(python3 "$LIB" sched-get "$SCHED_DIR" "$_sc_job_id" pid 2>/dev/null || echo "")
              if [[ -n "$_sc_pid" ]] && kill -0 "$_sc_pid" 2>/dev/null; then
                die "schedule cancel: currently running (PID $_sc_pid)"
              fi
              warn "stuck 'running' — cancelling stale job"
            fi
            _sc_backend=$(python3 "$LIB" sched-get "$SCHED_DIR" "$_sc_job_id" backend 2>/dev/null || echo "none")
            _sc_backend_id=$(python3 "$LIB" sched-get "$SCHED_DIR" "$_sc_job_id" backend_id 2>/dev/null || echo "none")
            _sched_cancel "$_sc_job_id" "$_sc_backend" "$_sc_backend_id"
            python3 "$LIB" sched-update "$SCHED_DIR" "$_sc_job_id" "status=cancelled"
            log "Cancelled: $_sc_job_id" ;;
    ""|--help|-h) cat <<'EOF'
ralph-core schedule — manage scheduled runs

  ./ralph/ralph-core schedule list
  ./ralph/ralph-core schedule show JOB_ID
  ./ralph/ralph-core schedule logs JOB_ID [--follow]
  ./ralph/ralph-core schedule cancel JOB_ID
EOF
            ;;
    *) echo "error: unknown schedule subcommand: $_SCHED_SUBCMD" >&2; exit 1 ;;
  esac
  ;;

# ─────────────────────────────────────────────────────────────────────────────
check)
  echo ""
  echo "ralph-core check — $CORE_ROOT"
  echo "══════════════════════════════════════"
  echo "account   : $ACCOUNT"
  echo "core repo : $CORE_REPO"
  echo "claude    : $CLAUDE_CONFIG_DIR"
  echo "codex     : $CODEX_HOME"
  echo "gh config : ${GH_CONFIG_DIR:-(default)}"
  echo "model     : $MODEL @ effort=$EFFORT"
  echo "codex mdl : $CODEX_MODEL"
  echo "feature   : ${FEATURE_BRANCH:-(not set)}"
  echo "schema    : $SCHEMA"
  echo ""

  echo "── Sub-repos ──"
  for dir in "$BACKEND_DIR" "$FRONTEND_DIR"; do
    name=$(basename "$dir")
    if [[ -d "$dir/.git" ]]; then
      branch=$(git -C "$dir" branch --show-current)
      status=$(git -C "$dir" status --short | wc -l | tr -d ' ')
      if _is_protected "$branch"; then
        printf "  %-30s ✗  on protected branch '%s' (%s uncommitted)\n" "$name" "$branch" "$status"
      else
        printf "  %-30s ✓  branch: %s (%s uncommitted)\n" "$name" "$branch" "$status"
      fi
    else
      printf "  %-30s ✗  NOT FOUND\n" "$name"
    fi
  done
  echo ""

  echo "── Auth ──"
  echo -n "  claude : "
  result=$(CLAUDE_CONFIG_DIR="$CLAUDE_CONFIG_DIR" claude --print 'reply: OK' 2>&1 | head -1) || true
  echo "$result" | grep -qi "OK" && echo "✓" || echo "✗  $result"
  echo -n "  gh     : "; gh api user --jq '.login' 2>&1 && true
  echo -n "  codex  : "; CODEX_HOME="$CODEX_HOME" codex --version 2>&1 | head -1
  echo ""

  echo "── Files ──"
  echo -n "  review schema    : "; [[ -f "$SCHEMA" ]] && echo "✓" || echo "✗  MISSING"
  echo -n "  workspace prompt : "; [[ -f "$RALPH_DIR/prompt.md" ]] && echo "✓" || echo "✗  MISSING"
  echo -n "  global prompt    : "; [[ -f "$HOME/.ralph/prompt.md" ]] && echo "✓" || echo "✗  MISSING"
  echo ""

  echo "── Lock ──"
  if [[ ! -f "$LOCK_FILE" ]]; then
    echo "  status : unlocked"
  else
    _lock_read_state
    if kill -0 "$_LOCK_PID" 2>/dev/null; then
      echo "  status : LOCKED (active PID $_LOCK_PID on ${_LOCK_HOST:-?})"
    elif [[ "${_LOCK_HOST:-}" != "$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo unknown)" ]]; then
      echo "  status : LOCKED (different host ${_LOCK_HOST:-?})"
    else
      echo "  status : stale lock (PID ${_LOCK_PID:-?} dead) — removing"
      if mkdir "${LOCK_FILE}.stale_lock" 2>/dev/null; then
        rm -f "$LOCK_FILE"
        rmdir "${LOCK_FILE}.stale_lock" 2>/dev/null || true
      fi
    fi
    echo "  command: ${_LOCK_CMD:-?}"
    echo "  started: ${_LOCK_STARTED:-?}"
  fi
  echo ""

  echo "── Issues ──"
  gh issue list --repo "$CORE_REPO" --state open \
    --label ready-for-agent --json number,title \
    --jq '.[] | "  #\(.number) \(.title)"' 2>/dev/null || echo "  (none)"
  echo ""
  ;;

# ─────────────────────────────────────────────────────────────────────────────
init)
  log "Initializing ralph-core workspace"
  for dir in "$BACKEND_DIR" "$FRONTEND_DIR"; do
    name=$(basename "$dir")
    [[ ! -d "$dir/.git" ]] && die "$name not found at $dir — run scripts/clone-repos.sh first"
    log "✓ $name exists"
  done

  if [[ -z "$FEATURE_BRANCH" ]]; then
    log "RALPH_FEATURE_BRANCH not set — skipping branch creation"
  else
    for dir in "$BACKEND_DIR" "$FRONTEND_DIR"; do
      name=$(basename "$dir")
      current=$(git -C "$dir" branch --show-current)
      if git -C "$dir" show-ref --verify --quiet "refs/heads/$FEATURE_BRANCH" 2>/dev/null; then
        log "✓ $name: '$FEATURE_BRANCH' already exists"
      elif _is_protected "$current"; then
        log "Creating '$FEATURE_BRANCH' from 'develop' in $name"
        git -C "$dir" stash --include-untracked 2>/dev/null || true
        git -C "$dir" checkout develop 2>/dev/null || die "Cannot checkout develop in $name"
        git -C "$dir" pull --ff-only origin develop 2>/dev/null || true
        git -C "$dir" checkout -b "$FEATURE_BRANCH"
      else
        log "✓ $name: already on non-protected branch '$current'"
      fi
    done
  fi

  mkdir -p "$RALPH_DIR/logs" "$RALPH_DIR/reviews" "$RUN_DIR" "$SCHED_DIR" "$SCHED_LOG_DIR"

  EXCLUDE_FILE="$CORE_ROOT/.git/info/exclude"
  for entry in "ralph/logs/" "ralph/reviews/" "ralph/runs/" "ralph/schedules/" "ralph/.run.lock"; do
    grep -qF "$entry" "$EXCLUDE_FILE" 2>/dev/null || echo "$entry" >> "$EXCLUDE_FILE"
  done

  for label in "ready-for-agent" "needs-triage" "needs-info" "ready-for-human"; do
    if gh label list --repo "$CORE_REPO" --json name --jq '.[].name' 2>/dev/null | grep -qF "$label"; then
      log "✓ Label '$label' exists"
    else
      gh label create "$label" --repo "$CORE_REPO" --color "0075ca" --description "" 2>/dev/null \
        && log "Created label '$label'" || warn "Could not create label '$label'"
    fi
  done

  _prune_stale
  log "Done. Run './ralph/ralph-core check' to verify."
  ;;

# ─────────────────────────────────────────────────────────────────────────────
ping)
  PING_SCHEDULE=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --schedule) [[ $# -lt 2 || -z "${2:-}" ]] && { echo "error: --schedule requires datetime" >&2; exit 1; }; PING_SCHEDULE="$2"; shift 2 ;;
      -*) echo "error: unknown flag: $1" >&2; exit 1 ;;
      *)  echo "error: unexpected argument: $1" >&2; exit 1 ;;
    esac
  done

  log "account : $ACCOUNT"
  log "model   : $MODEL"
  log "ping    : minimal Claude session to keep usage counter alive"

  if [[ -n "$PING_SCHEDULE" ]]; then
    _sched_parsed=$(python3 "$LIB" parse-dt "$PING_SCHEDULE" 2>&1) || die "$_sched_parsed"
    _sched_epoch=$(echo "$_sched_parsed" | cut -d' ' -f1)
    _sched_iso=$(echo "$_sched_parsed"   | cut -d' ' -f2)

    RALPH_PREFLIGHT_ALLOW_FUTURE_USAGE=1 RALPH_PREFLIGHT_SCHEDULE_EPOCH="$_sched_epoch"
    if ! _preflight "" "" "0"; then
      unset RALPH_PREFLIGHT_ALLOW_FUTURE_USAGE RALPH_PREFLIGHT_SCHEDULE_EPOCH
      exit 1
    fi
    unset RALPH_PREFLIGHT_ALLOW_FUTURE_USAGE RALPH_PREFLIGHT_SCHEDULE_EPOCH

    _sched_stored_cmd="ping"
    _sched_flags_json=$(python3 "$LIB" json-build "ping=true")
    if ! _schedule_create "$_sched_stored_cmd" "$_sched_flags_json" "0" \
      "$_sched_iso" "$_sched_epoch" "$JOURNAL_PREFLIGHT_DECISION" "${JOURNAL_PREFLIGHT_WARNINGS:-}"; then
      die "schedule: failed to register OS job for $_job_id"
    fi

    log "────────────────────────────────────────────"
    log "Scheduled  : $_job_id"
    log "  Command  : ping"
    log "  Run at   : $PING_SCHEDULE"
    log "  Backend  : ${_SCHED_BACKEND}"
    log "────────────────────────────────────────────"
    exit 0
  fi

  CLAUDE_CONFIG_DIR="$CLAUDE_CONFIG_DIR" claude --print 'reply: pong' 2>&1 | head -1
  log "ping complete"
  ;;

# ─────────────────────────────────────────────────────────────────────────────
*)
  echo "error: unknown subcommand: $CMD" >&2
  _usage >&2
  exit 1
  ;;
esac
